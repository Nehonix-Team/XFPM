<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>XFPM · Plugin Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    /* ── Base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --c:   #06080f;          /* canvas */
      --s1:  #0d1120;          /* surface 1 */
      --s2:  #111827;          /* surface 2 */
      --cyan: #00d4ff;
      --blue: #1e6bff;
      --cyan2: #00aacc;
      --border: rgba(0,212,255,.15);
      --border2: rgba(0,212,255,.3);
      --txt:  #dde6f0;
      --sub:  #6a7c93;
      --em:   #10b981;
      --err:  #ef4444;
      --modal-bg: rgba(10,14,23,.95);
    }

    html, body {
      min-height: 100vh;
      background: var(--c);
      font-family: 'Outfit', sans-serif;
      color: var(--txt);
      overflow-x: hidden;
      line-height: 1.6;
    }

    /* ── Ambient background ───────────────────────────── */
    .bg-glow {
      position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background:
        radial-gradient(ellipse 800px 500px at 50% -100px,  rgba(0,212,255,.08) 0%, transparent 70%),
        radial-gradient(ellipse 500px 400px at 90% 80%,    rgba(30,107,255,.07) 0%, transparent 60%),
        radial-gradient(ellipse 400px 300px at 10%  80%,    rgba(0,212,255,.05) 0%, transparent 60%);
    }

    .wrap {
      position: relative; z-index: 1;
      width: 100%; max-width: 860px;
      margin: 0 auto;
      padding: 60px 24px 140px;
    }

    /* ── Header ───────────────────────────────────────── */
    .hdr { text-align: center; margin-bottom: 48px; }

    .logo-row {
      display: inline-flex; align-items: center; gap: 10px;
      margin-bottom: 16px;
    }
    .logo-badge {
      display: flex; align-items: center; justify-content: center;
      width: 38px; height: 38px;
      background: linear-gradient(135deg, rgba(0,212,255,.15), rgba(30,107,255,.18));
      border: 1px solid var(--border2);
      border-radius: 10px;
      box-shadow: 0 0 16px rgba(0,212,255,.22);
    }
    .logo-name {
      font-size: 13px; font-weight: 800;
      letter-spacing: .25em; text-transform: uppercase;
      color: var(--sub);
    }

    .hdr h1 {
      font-size: 34px; font-weight: 800; letter-spacing: -.025em;
      background: linear-gradient(90deg, var(--cyan) 0%, #60b8ff 55%, var(--cyan) 100%);
      background-size: 200% auto;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 4s linear infinite;
      margin-bottom: 8px;
    }
    @keyframes shimmer { to { background-position: 200% center; } }

    .hdr p {
      font-size: 16px; color: var(--sub);
      line-height: 1.6;
      max-width: 500px; margin: 0 auto;
    }

    .hdr-divider {
      margin-top: 36px; height: 1px;
      background: linear-gradient(90deg, transparent, var(--cyan) 40%, var(--blue) 60%, transparent);
      opacity: .25;
    }

    /* ── Pills ────────────────────────────── */
    .count-pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 16px;
      background: rgba(0,212,255,.08);
      border: 1px solid var(--border);
      border-radius: 24px;
      font-size: 12px; font-weight: 600; letter-spacing: .06em;
      color: var(--sub);
      font-family: 'JetBrains Mono', monospace;
    }
    .count-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cyan); animation: blink 2s ease infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ── Plugin card ──────────────────────────────────── */
    .plugin-card {
      background: var(--s1);
      border: 1px solid var(--border);
      border-radius: 18px;
      overflow: hidden;
      margin-bottom: 18px;
      transition: all .25s;
      animation: fadeUp .35s ease both;
    }
    .plugin-card:hover {
      border-color: var(--border2);
      box-shadow: 0 0 32px rgba(0,212,255,.1), 0 4px 20px rgba(0,0,0,.4);
    }
    .plugin-card.card-selected {
      border-color: var(--cyan);
      background: rgba(0,212,255,.03);
    }
    @keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }

    .card-top {
      display: flex; align-items: center; gap: 16px;
      padding: 20px 24px;
      border-bottom: 1px solid rgba(255,255,255,.05);
      background: linear-gradient(135deg, rgba(30,107,255,.08), rgba(0,212,255,.04));
    }

    .avatar {
      flex-shrink: 0;
      width: 48px; height: 48px;
      background: linear-gradient(135deg, rgba(0,212,255,.2), rgba(30,107,255,.25));
      border: 1.5px solid rgba(0,212,255,.35);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 18px; color: var(--cyan);
      box-shadow: 0 0 14px rgba(0,212,255,.18);
    }

    .pending-card { opacity: 0.7; filter: grayscale(0.6); }
    .pending-card:hover { opacity: 0.9; filter: grayscale(0.2); }

    /* ── Modals ────────────────────────────── */
    .modal-overlay {
      display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(6,8,15,.88); backdrop-filter: blur(8px);
      align-items: center; justify-content: center;
      padding: 20px;
    }
    .modal-box {
      background: #0d111b; border: 1px solid var(--border);
      border-radius: 20px; padding: 32px; width: 100%; max-width: 440px;
      box-shadow: 0 24px 64px rgba(0,0,0,.8), 0 0 0 1px rgba(0,212,255,.1);
      animation: modalSlide .3s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @keyframes modalSlide { from{opacity:0;transform:translateY(20px) scale(0.98)} to{opacity:1;transform:none} }
    
    .modal-title { font-size: 22px; font-weight: 800; color: #fff; margin-bottom: 12px; letter-spacing: -0.02em; }
    .modal-desc  { font-size: 14px; color: var(--sub); margin-bottom: 24px; line-height: 1.6; }
    
    .modal-list {
      background: rgba(255,255,255,.03); border-radius: 12px;
      border: 1px solid rgba(255,255,255,.05);
      margin-bottom: 24px; max-height: 180px; overflow-y: auto;
      padding: 12px;
    }
    .modal-list-item { 
      padding: 8px 12px; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--cyan);
      display: flex; align-items: center; gap: 8px;
    }
    .modal-list-item::before { content: '→'; color: var(--sub); }

    .modal-actions { display: flex; justify-content: flex-end; gap: 12px; }
    .btn-modal-cancel { 
      background: transparent; color: var(--sub); border: none; 
      font-size: 14px; font-weight: 600; cursor: pointer; padding: 10px 20px; 
      transition: color .2s;
    }
    .btn-modal-cancel:hover { color: #fff; }

    .btn-modal-confirm { 
      background: var(--cyan); color: #000; border: none;
      border-radius: 10px; font-size: 14px; font-weight: 700; cursor: pointer; padding: 10px 24px;
      transition: all .2s;
    }
    .btn-modal-confirm:hover { transform: translateY(-2px); box-shadow: 0 0 20px rgba(0,212,255,0.4); }
    .btn-modal-confirm.btn-danger { background: var(--err); color: #fff; }

    /* ── Error Manager ────────────────────────────── */
    #error-manager {
      position: fixed; top: 24px; right: 24px; z-index: 10000;
      width: 380px; display: flex; flex-direction: column; gap: 12px;
      pointer-events: none;
    }
    .err-card {
      pointer-events: auto;
      background: rgba(20, 10, 10, 0.95); border: 1px solid rgba(239, 68, 68, 0.3);
      border-radius: 12px; padding: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      animation: errIn .4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
    }
    @keyframes errIn { from{opacity:0;transform:translateX(40px)} to{opacity:1;transform:none} }
    
    .err-top { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 8px; }
    .err-icon { 
      flex-shrink: 0; width: 20px; height: 20px; border-radius: 50%; 
      background: rgba(239,68,68,.2); color: var(--err);
      display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800;
    }
    .err-msg { flex: 1; font-size: 14px; font-weight: 600; color: #fecaca; line-height: 1.4; }
    .err-close { cursor: pointer; color: var(--sub); font-size: 18px; line-height: 1; }
    .err-close:hover { color: #fff; }

    .err-expand { 
      font-size: 11px; color: var(--sub); cursor: pointer; text-decoration: underline; 
      display: block; margin-top: 4px;
    }
    .err-details { 
      display: none; margin-top: 12px; padding: 10px; background: rgba(0,0,0,.4); 
      border-radius: 6px; font-family: 'JetBrains Mono', monospace; font-size: 10px;
      max-height: 150px; overflow: auto; color: #94a3b8; white-space: pre-wrap;
    }

    /* ── Toggles ────────────────────────────── */
    .toggle { position: relative; width: 44px; height: 24px; }
    .toggle input { opacity:0; width:0; height:0; }
    .tslider {
      position:absolute; inset:0; cursor:pointer;
      background: rgba(255,255,255,.09);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 24px;
      transition: all .28s;
    }
    .tslider::before {
      content:'';
      position:absolute; width:18px; height:18px;
      left:2px; top:2px;
      background: #4e6280; border-radius:50%;
      transition: all .28s;
    }
    .toggle input:checked + .tslider { background: rgba(0,212,255,.22); border-color: var(--cyan); }
    .toggle input:checked + .tslider::before { transform:translateX(20px); background:var(--cyan); box-shadow:0 0 10px var(--cyan); }

    /* ── Action bar ────────────────────────────── */
    .action-wrap {
      position: fixed; bottom: 0; left: 0; right: 0;
      display: flex; justify-content: center;
      padding: 24px 24px 32px;
      background: linear-gradient(to top, var(--c) 65%, transparent);
      z-index: 100;
      pointer-events: none;
    }
    .action-bar-inner { pointer-events: auto; }
    .action-bar {
      display: inline-flex; align-items: center; gap: 12px;
      padding: 10px 12px 10px 24px;
      background: rgba(10,13,22,.95);
      backdrop-filter: blur(24px);
      border: 1px solid var(--border);
      border-radius: 60px;
      box-shadow: 0 12px 48px rgba(0,0,0,.6), 0 0 0 1px rgba(0,212,255,.06);
    }

    .btn-pill {
      padding: 10px 24px; border-radius: 40px;
      font-size: 13px; font-weight: 700;
      letter-spacing: .05em; text-transform: uppercase;
      border: none; cursor: pointer; transition: all .2s;
    }
    .btn-pill-action { background: var(--cyan); color: #000; }
    .btn-pill-action:hover { box-shadow: 0 0 20px rgba(0,212,255,.3); transform: scale(1.02); }
    .btn-pill-danger { background: rgba(255, 77, 77, 0.15); color: #ff4d4d; border: 1px solid rgba(255, 77, 77, 0.3); }
    .btn-pill-danger:hover { background: rgba(255, 77, 77, 0.25); border-color: #ff4d4d; }

    /* Utilities */
    .btn-install { 
      background: rgba(0, 212, 255, 0.1); color: var(--cyan); border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; padding: 6px 16px;
      transition: all .2s; text-transform: uppercase;
    }
    .btn-install:hover { background: rgba(0, 212, 255, 0.2); border-color: var(--cyan); }
    
    .status-badge {
      font-size: 10px; font-weight: 800; padding: 2px 8px; border-radius: 4px; text-transform: uppercase;
      letter-spacing: .05em; margin-left: 8px; vertical-align: middle;
    }
    .status-authorized { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
    .status-pending { background: rgba(30, 107, 255, 0.1); color: var(--blue); border: 1px solid rgba(30, 107, 255, 0.2); }
    .status-not-installed { background: rgba(232, 121, 249, 0.1); color: #e879f9; border: 1px solid rgba(232, 121, 249, 0.2); }

    .btn-exit {
        position: fixed; top: 24px; left: 24px; z-index: 50;
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; border-radius: 12px;
        background: rgba(255,255,255,.03); border: 1px solid var(--border);
        color: var(--sub); font-size: 12px; font-weight: 700;
        cursor: pointer; transition: all .2s;
        backdrop-filter: blur(12px);
    }
    .btn-exit:hover { background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.3); color: var(--err); transform: translateX(2px); }

    .discovery-overlay {
      position: fixed; inset: 0; z-index: 20000;
      background: rgba(8, 12, 20, 0.92); backdrop-filter: blur(12px);
      display: none; flex-direction: column; align-items: center; justify-content: center;
      animation: fadeIn .4s ease both;
    }
    .discovery-box { text-align: center; max-width: 400px; padding: 40px; }
    .loader-ring {
      width: 64px; height: 64px; border: 4px solid rgba(0, 212, 255, 0.1);
      border-top-color: var(--cyan); border-radius: 50%;
      margin: 0 auto 24px; animation: spin 1s linear infinite;
      box-shadow: 0 0 20px rgba(0, 212, 255, 0.2);
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .toast {
      position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%);
      background: rgba(16, 185, 129, 0.95); color: #fff;
      padding: 12px 24px; border-radius: 40px; font-weight: 600; font-size: 14px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.5);
      z-index: 500; display: none;
      animation: toastIn .3s ease both;
    }
    @keyframes toastIn { from{opacity:0;bottom:80px} to{opacity:1;bottom:100px} }
  </style>
</head>
<body>

  <div class="bg-glow"></div>
  <div id="error-manager"></div>
  <div id="success-toast" class="toast">Changes applied successfully.</div>

  <!-- Discovery Overlay -->
  <div id="discovery-overlay" class="discovery-overlay">
    <div class="discovery-box">
      <div class="loader-ring"></div>
      <h2 style="font-size:24px; font-weight:800; color:#fff; margin-bottom:8px;">Discovery in Progress</h2>
      <p id="discovery-msg" style="color:var(--sub); font-size:14px; line-height:1.6; margin-bottom:24px;">New plugins detected. Re-scanning system metadata...</p>
      <div style="height:4px; width:100%; background:rgba(255,255,255,0.05); border-radius:2px; overflow:hidden;">
        <div id="discovery-progress" style="height:100%; width:0%; background:var(--cyan); transition:width .3s ease;"></div>
      </div>
    </div>
  </div>

  <div class="fixed top-6 left-6 flex items-center gap-3 z-50">
    <button class="btn-exit" onclick="doCancel()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      EXIT SESSION
    </button>
    <button class="btn-exit" style="padding: 10px; width: auto;" onclick="restartSession()" title="Deep Discovery Restart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
    </button>
  </div>

  <div class="wrap">
    <header class="hdr">
      <div class="logo-row">
        <div class="logo-badge">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
            <polygon points="10,1 18,5.5 18,14.5 10,19 2,14.5 2,5.5" fill="none" stroke="url(#lg)" stroke-width="1.4"/>
            <defs>
              <linearGradient id="lg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#00d4ff"/><stop offset="100%" stop-color="#1e6bff"/></linearGradient>
            </defs>
            <path d="M7 10l2 2 4-4" stroke="#00d4ff" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="logo-name">XFPM</span>
      </div>
      <h1>{{if .IsReview}}Plugin Review{{else}}Plugin Verification{{end}}</h1>
      <p>Review and manage plugin privileges for your system.</p>
      <div class="hdr-divider"></div>
    </header>

    <form id="vform">
      <div style="text-align:center;margin-bottom:24px;display:flex;align-items:center;justify-content:center;gap:12px;">
        <span class="count-pill">
          <span class="count-dot"></span>
          {{len .Plugins}} plugin(s) found
        </span>
        <label style="cursor:pointer;background:rgba(255,255,255,.05);padding:6px 14px;border-radius:24px;border:1px solid var(--border);display:flex;align-items:center;gap:8px;">
          <input type="checkbox" class="w-4 h-4 accent-cyan" id="select-all" onclick="toggleSelectAll(this.checked)">
          <span style="font-size:11px;font-weight:700;color:var(--sub);font-family:'JetBrains Mono',monospace;text-transform:uppercase;">Select All</span>
        </label>
      </div>

      {{range $i, $p := .Plugins}}
      <div class="plugin-card{{if ne .Status "authorized"}} pending-card{{end}}" id="card-{{.Name}}">
        <div class="card-top">
          <input type="checkbox" class="xchk plugin-select w-5 h-5 accent-cyan" data-name="{{.Name}}" data-version="{{.Version}}" data-status="{{.Status}}" onchange="onSelectionChange()">
          <div class="avatar">{{slice .Name 0 1}}</div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:18px;font-weight:700;color:#fff;" class="truncate">
              {{.Name}}
              <span id="status-badge-{{.Name}}">
                {{if eq .Status "authorized"}}<span class="status-badge status-authorized">Authorized</span>
                {{else if eq .Status "NOT_INSTALLED"}}<span class="status-badge status-not-installed">Not Installed</span>
                {{else}}<span class="status-badge status-pending">Pending</span>{{end}}
              </span>
            </div>
            <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--sub);margin-top:2px;">{{.Identity}}</div>
          </div>
          <div class="trust-wrap" id="action-wrap-{{.Name}}">
            {{if eq .Status "authorized"}}
              <button type="button" class="btn-install" style="background:transparent;border-color:rgba(239,68,68,.3);color:#ef4444;" onclick="showRevokeModal('{{.Name}}')">Revoke</button>
            {{else if eq .Status "NOT_INSTALLED"}}
              <button type="button" class="btn-install" id="install-btn-{{.Name}}" onclick="showInstallModal('{{.Name}}', '{{.Version}}')">Install</button>
            {{else}}
              <div style="display:flex;align-items:center;gap:8px;">
                <span style="font-size:12px;color:var(--sub);font-weight:600;">Trust</span>
                <label class="toggle"><input type="checkbox" id="trust-{{.Name}}" name="trust-{{.Name}}" {{if or (eq .Status "authorized") (not $.IsReview)}}checked{{end}} /><span class="tslider"></span></label>
              </div>
            {{end}}
          </div>
        </div>

        <div style="padding:18px 24px;">
          <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:var(--sub);margin-bottom:12px;letter-spacing:.1em;">Privileges</div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="privs-grid-{{.Name}}">
            {{range .RequestedPrivileges}}
            <label class="flex gap-3 p-3 bg-[rgba(255,255,255,.02)] border border-[rgba(255,255,255,.05)] rounded-xl cursor-pointer hover:bg-[rgba(0,212,255,.04)] hover:border-[rgba(0,212,255,.1)] transition-all">
              <input type="checkbox" name="perm-{{$p.Name}}-{{.ID}}" class="xchk w-4 h-4 accent-cyan mt-0.5" {{if .Approved}}checked{{end}} />
              <div>
                <div style="font-size:14px;font-weight:600;color:#fff;">{{.Name}}</div>
                <div style="font-size:12px;color:var(--sub);margin-bottom:4px;">{{.Description}}</div>
                <span class="px-2 py-0.5 bg-[rgba(0,212,255,.1)] border border-[rgba(0,212,255,.2)] rounded text-[10px] text-cyan-400 font-mono">{{.ID}}</span>
              </div>
            </label>
            {{else}}<div class="col-span-full py-4 text-center text-sm text-[var(--sub)] italic">Standard privileges only.</div>{{end}}
          </div>
        </div>
      </div>
      {{end}}

      <div class="action-wrap">
        <div class="action-bar-inner">
          <div class="action-bar">
            <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--sub);font-family:'JetBrains Mono';font-weight:500;margin-right:8px;"><span class="count-dot"></span>ready</div>
            <button type="button" class="btn-pill btn-pill-danger" id="btn-batch-revoke" style="display:none;" onclick="showBatchRevokeModal()">Revoke Selected</button>
            <button type="button" class="btn-pill btn-pill-action" id="btn-batch-install" style="display:none;" onclick="showBatchInstallModal()">Install Selected</button>
            <div style="width:1px;height:24px;background:var(--border);margin:0 4px;" id="action-divider"></div>
            <button type="button" style="color:var(--sub);font-weight:600;font-size:14px;padding:0 12px;cursor:pointer;" onclick="doCancel()">Cancel</button>
            <button type="button" class="btn-pill btn-pill-action" onclick="showApplyModal()">{{if .IsReview}}Apply Changes{{else}}Authorize Selection{{end}}</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <!-- Unified Modal Overlay -->
  <div id="modal-overlay" class="modal-overlay">
    <div class="modal-box">
      <h2 id="modal-title" class="modal-title">Confirm Action</h2>
      <p id="modal-desc" class="modal-desc">Are you sure you want to proceed?</p>
      <div id="modal-list-container" style="display:none;">
        <div class="modal-list" id="modal-list"></div>
      </div>
      
      <div id="modal-options-container" style="display:none;" class="mb-6 space-y-3">
        <!-- Revoke Options -->
        <div id="revoke-options" style="display:none;" class="space-y-3">
            <label class="flex gap-3 p-3 bg-[rgba(255,255,255,.03)] border border-[rgba(255,255,255,.05)] rounded-xl cursor-pointer">
              <input type="radio" name="revoke-opt" value="false" checked class="accent-cyan w-4 h-4 mt-1">
              <div><div class="text-sm font-semibold">Move to pending</div><div class="text-[11px] text-gray-500">Requires re-authorization.</div></div>
            </label>
            <label class="flex gap-3 p-3 bg-[rgba(255,255,255,.03)] border border-[rgba(255,255,255,.05)] rounded-xl cursor-pointer">
              <input type="radio" name="revoke-opt" value="true" class="accent-cyan w-4 h-4 mt-1">
              <div><div class="text-sm font-semibold">Full Uninstall</div><div class="text-[11px] text-gray-500">Removes files physically.</div></div>
            </label>
        </div>
        <!-- Apply Options -->
        <div id="apply-options" style="display:none;" class="space-y-3">
            <label class="flex items-center gap-3 p-3 bg-[rgba(255,255,255,.03)] border border-[rgba(0,212,255,.1)] rounded-xl cursor-pointer">
              <input type="checkbox" id="close-after-apply" checked class="accent-cyan w-4 h-4">
              <div><div class="text-sm font-semibold">Terminate session after applying</div><div class="text-[11px] text-gray-500">Closes the terminal and this tab.</div></div>
            </label>
        </div>
      </div>
      
      <div class="modal-actions">
        <button type="button" class="btn-modal-cancel" onclick="closeModal()">Cancel</button>
        <button type="button" id="modal-confirm" class="btn-modal-confirm">Confirm</button>
      </div>
    </div>
  </div>

  <script>
    // banner
    function banner() {
      const _c = (t, s) => console.log(`%c${t}`, s);
      const muted = "color:#6B7A99;font-weight:400;font-family:monospace;";
      const link  = "color:#00C2FF;font-weight:400;font-family:monospace;";
      const tag   = "color:#7DF9FF;font-weight:400;font-family:monospace;letter-spacing:2px;";

      console.groupCollapsed(
        "%c NEHONIX %c XFPM ",
        "background:linear-gradient(90deg,#1B0A3F,#2D1B6E);color:#00C2FF;font-weight:800;padding:3px 10px;border-radius:4px 0 0 4px;font-family:monospace;letter-spacing:1px;border:1px solid #00C2FF44;",
        "background:linear-gradient(90deg,#0A1628,#0D2044);color:#7DF9FF;font-weight:700;padding:3px 10px;border-radius:0 4px 4px 0;font-family:monospace;letter-spacing:3px;border:1px solid #7DF9FF44;border-left:none;"
      );
      _c("  FAST · HIGH-PERFORMANCE · RELIABLE", tag);
      _c("  ─────────────────────────────────", "color:#1E3A5F;");
      _c("  github    github.com/Nehonix-Team/XFPM", link);
      _c("  about     XyPriss Fast Package Manager", muted);
      console.groupEnd();
    }
    // --- Error Management ---
    function showError(msg, details = null) {
      const mgr = document.getElementById('error-manager');
      const id = 'err-' + Date.now();
      const div = document.createElement('div');
      div.className = 'err-card';
      div.id = id;
      
      let detailsHtml = '';
      if (details) {
        const detailsStr = typeof details === 'object' ? JSON.stringify(details, null, 2) : details;
        detailsHtml = `<span class="err-expand" onclick="toggleErr('${id}')">Show technical details</span><pre class="err-details" id="det-${id}">${detailsStr}</pre>`;
      }

      div.innerHTML = `<div class="err-top"><div class="err-icon">!</div><div class="err-msg">${msg}</div><div class="err-close" onclick="this.parentElement.parentElement.remove()">×</div></div>${detailsHtml}`;
      mgr.appendChild(div);
      setTimeout(() => { if(document.getElementById(id)) document.getElementById(id).style.opacity = '0.7'; }, 8000);
    }
    function toggleErr(id) {
      const el = document.getElementById('det-' + id);
      el.style.display = el.style.display === 'block' ? 'none' : 'block';
    }

    // --- Toast ---
    function showToast(msg) {
        const t = document.getElementById('success-toast');
        t.innerText = msg; t.style.display = 'block';
        setTimeout(() => t.style.display = 'none', 3000);
    }

    // --- Modal System ---
    function showModal({ title, desc, action, items = [], isDanger = false, showRevokeOpts = false, showApplyOpts = false }) {
      document.getElementById('modal-title').innerText = title;
      document.getElementById('modal-desc').innerText = desc;
      const listCont = document.getElementById('modal-list-container');
      const listEl = document.getElementById('modal-list');
      const optCont = document.getElementById('modal-options-container');
      const revOpts = document.getElementById('revoke-options');
      const appOpts = document.getElementById('apply-options');
      
      listEl.innerHTML = '';
      if (items.length > 0) {
        listCont.style.display = 'block';
        items.forEach(it => {
          const div = document.createElement('div');
          div.className = 'modal-list-item';
          div.innerText = it;
          listEl.appendChild(div);
        });
      } else { listCont.style.display = 'none'; }
      
      optCont.style.display = (showRevokeOpts || showApplyOpts) ? 'block' : 'none';
      revOpts.style.display = showRevokeOpts ? 'block' : 'none';
      appOpts.style.display = showApplyOpts ? 'block' : 'none';
      
      const confirmBtn = document.getElementById('modal-confirm');
      confirmBtn.className = 'btn-modal-confirm' + (isDanger ? ' btn-danger' : '');
      confirmBtn.onclick = async () => {
        confirmBtn.disabled = true; confirmBtn.innerText = 'Processing...';
        try { await action(); closeModal(); } catch(e) { showError('Action failed', e); }
        finally { confirmBtn.disabled = false; confirmBtn.innerText = 'Confirm'; }
      }
      
      document.getElementById('modal-overlay').style.display = 'flex';
    }
    function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }

    // --- Core Logic ---
    function toggleSelectAll(checked) {
      document.querySelectorAll('.plugin-select').forEach(el => el.checked = checked);
      onSelectionChange();
    }

    function onSelectionChange() {
      const selected = Array.from(document.querySelectorAll('.plugin-select:checked'));
      const revokeBtn = document.getElementById('btn-batch-revoke');
      const installBtn = document.getElementById('btn-batch-install');
      const divider = document.getElementById('action-divider');
      
      const authSelected = selected.filter(el => el.dataset.status === 'authorized');
      const uninstalledSelected = selected.filter(el => el.dataset.status === 'NOT_INSTALLED');
      
      revokeBtn.style.display = authSelected.length > 0 ? 'block' : 'none';
      revokeBtn.innerText = `Revoke (${authSelected.length})`;
      
      installBtn.style.display = uninstalledSelected.length > 0 ? 'block' : 'none';
      installBtn.innerText = `Install (${uninstalledSelected.length})`;
      
      divider.style.display = (authSelected.length || uninstalledSelected.length) ? 'block' : 'none';

      document.querySelectorAll('.plugin-card').forEach(c => c.classList.remove('card-selected'));
      selected.forEach(el => document.getElementById('card-' + el.dataset.name)?.classList.add('card-selected'));
    }

    async function handleApply() {
        const formData = {};
        new FormData(document.getElementById('vform')).forEach((v, k) => formData[k] = v);
        const shouldClose = document.getElementById('close-after-apply').checked;

        const r = await fetch('/apply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: formData, close: shouldClose })
        });
        
        if (r.ok) {
            if (shouldClose) {
                document.body.innerHTML = `<div class="flex items-center justify-center min-h-screen"><div class="text-center animate-pulse"><div class="w-16 h-16 bg-green-500/20 border border-green-500/40 rounded-full flex items-center justify-center mx-auto mb-6"><svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></div><h2 class="text-2xl font-bold text-white mb-2">Config Saved</h2><p class="text-gray-500">Terminating session...</p></div></div>`;
                setTimeout(() => window.close(), 1500);
            } else {
                showToast('Configuration applied. Session remains active.');
            }
        } else throw await r.json().catch(() => ({ error: 'Apply failed' }));
    }

    async function handleRevoke(packages, noPending) {
        const body = packages.length === 1 
            ? new URLSearchParams({ package: packages[0], noPending }) 
            : JSON.stringify({ packages, noPending });
        const endpoint = packages.length === 1 ? '/revoke' : '/revoke-batch';
        const headers = packages.length === 1 ? {} : { 'Content-Type': 'application/json' };

        const r = await fetch(endpoint, { method: 'POST', body, headers });
        if (!r.ok) throw await r.json().catch(() => ({ error: 'Revocation failed' }));
        showToast(`Revoked ${packages.length} plugin(s).`);
    }

    async function handleInstall(packages) {
        const endpoint = packages.length === 1 ? '/install' : '/install-batch';
        const body = packages.length === 1 
            ? new URLSearchParams({ package: packages[0].name, version: packages[0].version }) 
            : JSON.stringify({ packages });
        const headers = packages.length === 1 ? {} : { 'Content-Type': 'application/json' };

        const r = await fetch(endpoint, { method: 'POST', body, headers });
        if (!r.ok) throw await r.json().catch(() => ({ error: 'Installation failed' }));
        
        showDiscoveryOverlay();
        setTimeout(restartSession, 500); // Trigger auto-refresh after a tiny delay for visual impact
    }

    function showDiscoveryOverlay() {
        document.getElementById('discovery-overlay').style.display = 'flex';
    }

    function showApplyModal() {
        showModal({
            title: 'Apply Changes',
            desc: 'Save your configuration updates.',
            showApplyOpts: true,
            action: handleApply
        });
    }

    function showRevokeModal(name) {
      showModal({ title: 'Revoke Trust', desc: `Revoke authorization for "${name}"?`, isDanger: true, showRevokeOpts: true, action: () => handleRevoke([name], document.querySelector('input[name="revoke-opt"]:checked').value === "true") });
    }

    function showBatchRevokeModal() {
      const selected = Array.from(document.querySelectorAll('.plugin-select:checked')).filter(el => el.dataset.status === 'authorized').map(el => el.dataset.name);
      showModal({ title: `Batch Revoke (${selected.length})`, desc: `Revoke trust for selected plugins?`, items: selected, isDanger: true, showRevokeOpts: true, action: () => handleRevoke(selected, document.querySelector('input[name="revoke-opt"]:checked').value === "true") });
    }

    function showInstallModal(name, version) {
      showModal({ title: 'Install Plugin', desc: `Install ${name}@${version}?`, action: () => handleInstall([{name, version}]) });
    }

    function showBatchInstallModal() {
      const selected = Array.from(document.querySelectorAll('.plugin-select:checked')).filter(el => el.dataset.status === 'NOT_INSTALLED').map(el => ({ name: el.dataset.name, version: el.dataset.version }));
      showModal({ title: `Batch Install (${selected.length})`, desc: `Install selected plugins?`, items: selected.map(s => `${s.name}@${s.version}`), action: () => handleInstall(selected) });
    }

    function doCancel() {
      showModal({ title: 'Terminate Session', desc: 'Exit the plugin management session and return to terminal?', isDanger: true, action: () => fetch('/cancel', { method: 'POST' }).then(() => window.close()) });
    }

    async function restartSession() {
        const btn = (typeof event !== 'undefined' && event) ? event.currentTarget : null;
        if (btn && btn.classList) btn.classList.add('animate-spin');
        try {
            await fetch('/restart');
        } catch(e) { console.error(e); }
        finally { if (btn && btn.classList) setTimeout(() => btn.classList.remove('animate-spin'), 1000); }
    }

    // --- SSE Sync ---
    const es = new EventSource('/events');
    es.addEventListener('reload', () => { window.location.reload(); });
    es.addEventListener('close', () => { window.close(); document.body.innerHTML = `<div class="flex items-center justify-center min-h-screen"><div class="text-center"><div class="success-icon" style="background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3)"><svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"/></svg></div><h2 class="text-xl font-bold text-white">Session Terminated</h2></div></div>`; });
    es.onmessage = (e) => { try { updateDashboard(JSON.parse(e.data)); } catch(err) { console.error(err); } };
    es.addEventListener('progress', (e) => {
        const data = JSON.parse(e.data);
        showDiscoveryOverlay();
        document.getElementById('discovery-progress').style.width = data.percent + '%';
        document.getElementById('discovery-msg').innerText = data.msg;
    });

    function updateDashboard(plugins) {
      plugins.forEach(p => {
        const card = document.getElementById('card-' + p.name);
        if (!card) return;
        card.classList.toggle('pending-card', p.status !== 'authorized');
        const badge = document.getElementById('status-badge-' + p.name);
        if (badge) {
          if (p.status === 'authorized') badge.innerHTML = '<span class="status-badge status-authorized">Authorized</span>';
          else if (p.status === 'NOT_INSTALLED') badge.innerHTML = '<span class="status-badge status-not-installed">Not Installed</span>';
          else badge.innerHTML = '<span class="status-badge status-pending">Pending</span>';
        }
        const select = card.querySelector('.plugin-select');
        if (select) select.dataset.status = p.status;
        
        const wrap = document.getElementById('action-wrap-' + p.name);
        if (wrap) {
          if (p.status === 'authorized') wrap.innerHTML = `<button type="button" class="btn-install" style="background:transparent;border-color:rgba(239,68,68,.3);color:#ef4444;" onclick="showRevokeModal('${p.name}')">Revoke</button>`;
          else if (p.status === 'NOT_INSTALLED') wrap.innerHTML = `<button type="button" class="btn-install" onclick="showInstallModal('${p.name}', '${p.version}')">Install</button>`;
          else wrap.innerHTML = `<div class="flex items-center gap-2"><span class="text-xs text-[var(--sub)] font-semibold">Trust</span><label class="toggle"><input type="checkbox" id="trust-${p.name}" name="trust-${p.name}" ${p.status==='authorized' || !{{.IsReview}} ? 'checked':''} /><span class="tslider"></span></label></div>`;
        }

        const privsGrid = document.getElementById('privs-grid-' + p.name);
        if (privsGrid && p.requested_privileges) {
            if (p.requested_privileges.length === 0) {
                privsGrid.innerHTML = `<div class="col-span-full py-4 text-center text-sm text-[var(--sub)] italic">Standard privileges only.</div>`;
            } else {
                privsGrid.innerHTML = p.requested_privileges.map(pr => `
                    <label class="flex gap-3 p-3 bg-[rgba(255,255,255,.02)] border border-[rgba(255,255,255,.05)] rounded-xl cursor-pointer hover:bg-[rgba(0,212,255,.04)] hover:border-[rgba(0,212,255,.1)] transition-all">
                      <input type="checkbox" name="perm-${p.name}-${pr.id}" class="xchk w-4 h-4 accent-cyan mt-0.5" ${pr.approved ? 'checked' : ''} />
                      <div>
                        <div style="font-size:14px;font-weight:600;color:#fff;">${pr.name}</div>
                        <div style="font-size:12px;color:var(--sub);margin-bottom:4px;">${pr.description}</div>
                        <span class="px-2 py-0.5 bg-[rgba(0,212,255,.1)] border border-[rgba(0,212,255,.2)] rounded text-[10px] text-cyan-400 font-mono">${pr.id}</span>
                      </div>
                    </label>
                `).join('');
            }
        }
      });
      onSelectionChange();
    }
    banner()
  </script>
</body>
</html>
