<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>XFPM · Plugin Verification</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    /* ── Base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --c:   #06080f;          /* canvas */
      --s1:  #0d1120;          /* surface 1 */
      --s2:  #111827;          /* surface 2 */
      --cyan: #00d4ff;
      --blue: #1e6bff;
      --cyan2: #00aacc;
      --border: rgba(0,212,255,.15);
      --border2: rgba(0,212,255,.3);
      --txt:  #dde6f0;
      --sub:  #6a7c93;         /* Slightly brighter subtext for readability */
      --em:   #10b981;
    }

    html, body {
      min-height: 100vh;
      background: var(--c);
      font-family: 'Outfit', sans-serif;
      color: var(--txt);
      overflow-x: hidden;
      line-height: 1.6;        /* Better reading rhythm */
    }

    /* ── Ambient background ───────────────────────────── */
    .bg-glow {
      position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background:
        radial-gradient(ellipse 800px 500px at 50% -100px,  rgba(0,212,255,.08) 0%, transparent 70%),
        radial-gradient(ellipse 500px 400px at 90% 80%,    rgba(30,107,255,.07) 0%, transparent 60%),
        radial-gradient(ellipse 400px 300px at 10%  80%,    rgba(0,212,255,.05) 0%, transparent 60%);
    }

    /* ── Layout wrapper ───────────────────────────────── */
    .wrap {
      position: relative; z-index: 1;
      width: 100%; max-width: 860px;   /* Increased from 680px */
      margin: 0 auto;
      padding: 60px 24px 140px;        /* More breathing room */
    }

    /* ── Header ───────────────────────────────────────── */
    .hdr { text-align: center; margin-bottom: 48px; }

    .logo-row {
      display: inline-flex; align-items: center; gap: 10px;
      margin-bottom: 16px;
    }
    .logo-badge {
      display: flex; align-items: center; justify-content: center;
      width: 38px; height: 38px;
      background: linear-gradient(135deg, rgba(0,212,255,.15), rgba(30,107,255,.18));
      border: 1px solid var(--border2);
      border-radius: 10px;
      box-shadow: 0 0 16px rgba(0,212,255,.22);
    }
    .logo-name {
      font-size: 13px; font-weight: 800;
      letter-spacing: .25em; text-transform: uppercase;
      color: var(--sub);
    }

    .hdr h1 {
      font-size: 34px; font-weight: 800; letter-spacing: -.025em;
      background: linear-gradient(90deg, var(--cyan) 0%, #60b8ff 55%, var(--cyan) 100%);
      background-size: 200% auto;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 4s linear infinite;
      margin-bottom: 8px;
    }
    @keyframes shimmer { to { background-position: 200% center; } }

    .hdr p {
      font-size: 16px; color: var(--sub);
      line-height: 1.6;
      max-width: 500px; margin: 0 auto;
    }

    .hdr-divider {
      margin-top: 36px; height: 1px;
      background: linear-gradient(90deg, transparent, var(--cyan) 40%, var(--blue) 60%, transparent);
      opacity: .25;
    }

    /* ── Plugin count pill ────────────────────────────── */
    .count-pill {
      display: inline-flex; align-items: center; gap: 8px;
      margin-bottom: 24px;
      padding: 6px 16px;
      background: rgba(0,212,255,.08);
      border: 1px solid var(--border);
      border-radius: 24px;
      font-size: 12px; font-weight: 600; letter-spacing: .06em;
      color: var(--sub);
      font-family: 'JetBrains Mono', monospace;
    }
    .count-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--cyan); animation: blink 2s ease infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* ── Plugin card ──────────────────────────────────── */
    .plugin-card {
      background: var(--s1);
      border: 1px solid var(--border);
      border-radius: 18px;
      overflow: hidden;
      margin-bottom: 18px;
      transition: border-color .25s, box-shadow .25s;
      animation: fadeUp .35s ease both;
    }
    .plugin-card:hover {
      border-color: var(--border2);
      box-shadow: 0 0 32px rgba(0,212,255,.1), 0 4px 20px rgba(0,0,0,.4);
    }
    .plugin-card:nth-child(1){animation-delay:.04s}
    .plugin-card:nth-child(2){animation-delay:.09s}
    .plugin-card:nth-child(3){animation-delay:.14s}
    .plugin-card:nth-child(4){animation-delay:.19s}
    @keyframes fadeUp { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }

    /* card top row */
    .card-top {
      display: flex; align-items: center; gap: 16px;
      padding: 20px 24px;
      border-bottom: 1px solid rgba(255,255,255,.05);
      background: linear-gradient(135deg, rgba(30,107,255,.08), rgba(0,212,255,.04));
    }

    /* avatar hex */
    .avatar {
      flex-shrink: 0;
      width: 48px; height: 48px;
      background: linear-gradient(135deg, rgba(0,212,255,.2), rgba(30,107,255,.25));
      border: 1.5px solid rgba(0,212,255,.35);
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 18px; color: var(--cyan);
      box-shadow: 0 0 14px rgba(0,212,255,.18);
    }

    .pending-card {
      opacity: 0.6;
      filter: grayscale(0.8);
      transition: all 0.3s;
    }
    .pending-card:hover {
      opacity: 0.8;
      filter: grayscale(0.2);
    }

    /* custom modal */
    #revoke-modal {
      display: none; position: fixed; inset: 0; z-index: 9999;
      background: rgba(10,14,23,.85); backdrop-filter: blur(4px);
      align-items: center; justify-content: center;
    }
    .modal-box {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 12px; padding: 24px; width: 400px;
      box-shadow: 0 12px 32px rgba(0,0,0,.6);
      animation: fadeUp .2s ease both;
    }
    .modal-title { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .modal-desc  { font-size: 13px; color: var(--sub); margin-bottom: 18px; line-height: 1.5; }
    
    .modal-opts { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
    .modal-opt { display: flex; gap: 10px; align-items: flex-start; cursor: pointer; }
    .modal-opt input { margin-top: 3px; accent-color: var(--cyan); }
    .modal-opt div { font-size: 13px; color: #dde6f0; }
    .modal-opt div span { display: block; font-size: 11px; color: var(--sub); margin-top: 2px; }

    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; }
    .btn-modal-cancel { 
      background: transparent; color: var(--sub); border: none; 
      font-size: 13px; font-weight: 600; cursor: pointer; padding: 8px 16px; 
    }
    .btn-modal-confirm { 
      background: rgba(255, 77, 77, 0.1); color: #ff4d4d; border: 1px solid rgba(255, 77, 77, 0.2);
      border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; padding: 8px 16px;
      transition: all .2s;
    }
    .btn-modal-confirm:hover { background: rgba(255, 77, 77, 0.2); }

    .btn-install { 
      background: rgba(0, 212, 255, 0.1); color: var(--cyan); border: 1px solid rgba(0, 212, 255, 0.2);
      border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; padding: 6px 14px;
      transition: all .2s;
    }
    .btn-install:hover { background: rgba(0, 212, 255, 0.2); box-shadow: 0 0 10px rgba(0, 212, 255, 0.2); }

    .card-meta { flex: 1; min-width: 0; }
    .card-name {
      font-size: 18px; font-weight: 700;
      color: #fff; letter-spacing: -.01em;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .card-dev {
      display: flex; align-items: center; gap: 6px;
      margin-top: 4px;
      font-family: 'JetBrains Mono', monospace; font-size: 11px;
    }
    .dev-label { color: var(--sub); font-weight: 600; }
    .dev-id    { color: var(--cyan2); opacity: .85; }

    /* trust toggle */
    .trust-wrap { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .trust-lbl  { font-size: 13px; font-weight: 500; color: var(--sub); }

    .toggle { position: relative; width: 44px; height: 24px; }
    .toggle input { opacity:0; width:0; height:0; }
    .tslider {
      position:absolute; inset:0; cursor:pointer;
      background: rgba(255,255,255,.09);
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 24px;
      transition: all .28s;
    }
    .tslider::before {
      content:'';
      position:absolute; width:18px; height:18px;
      left:2px; top:2px;
      background: #4e6280; border-radius:50%;
      transition: all .28s;
    }
    .toggle input:checked + .tslider { background: rgba(0,212,255,.22); border-color: var(--cyan); }
    .toggle input:checked + .tslider::before { transform:translateX(20px); background:var(--cyan); box-shadow:0 0 10px var(--cyan); }

    /* privileges section */
    .privs { padding: 18px 24px; }

    .privs-label {
      font-size: 11px; font-weight: 700; letter-spacing: .16em;
      text-transform: uppercase; color: var(--sub);
      margin-bottom: 16px;
      display: flex; align-items: center; gap: 10px;
    }
    .privs-label::after { content:''; flex:1; height:1px; background:rgba(255,255,255,.06); }

    .priv-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); /* Wider items */
      gap: 12px;
    }

    .priv-item {
      display: flex; gap: 14px; align-items: flex-start;
      padding: 14px 18px;
      background: rgba(255,255,255,.025);
      border: 1px solid rgba(255,255,255,.06);
      border-radius: 12px;
      cursor: pointer;
      transition: background .2s, border-color .2s, transform .2s;
    }
    .priv-item:hover { 
      background: rgba(0,212,255,.05); 
      border-color: rgba(0,212,255,.18);
      transform: translateY(-2px);
    }

    /* custom checkbox */
    .xchk {
      appearance:none; flex-shrink:0;
      width:18px; height:18px; margin-top:3px;
      border: 1.5px solid rgba(0,212,255,.4);
      border-radius: 5px;
      background: rgba(0,212,255,.08);
      cursor: pointer;
      position: relative;
      transition: all .2s;
    }
    .xchk:checked {
      background: linear-gradient(135deg, var(--blue), var(--cyan));
      border-color: var(--cyan);
    }
    .xchk:checked::after {
      content:''; position:absolute;
      left:5px; top:1px; width:6px; height:11px;
      border: 2px solid #fff; border-top:none; border-left:none;
      transform: rotate(45deg);
    }
    .xchk:focus { outline:none; box-shadow:0 0 0 3px rgba(0,212,255,.25); }

    .priv-body { flex:1; min-width:0; }
    .priv-name {
      font-size: 14px; font-weight: 600; color: #fff;
      margin-bottom: 5px; line-height: 1.3;
    }
    .priv-desc {
      font-size: 13px; color: var(--sub); line-height: 1.55;
      margin-bottom: 10px;
    }
    .priv-id {
      display: inline-block;
      font-family: 'JetBrains Mono', monospace; font-size: 10px;
      padding: 3px 10px;
      background: rgba(0,212,255,.09);
      border: 1px solid rgba(0,212,255,.22);
      border-radius: 5px;
      color: var(--cyan); letter-spacing: .08em; text-transform: uppercase;
      font-weight: 500;
    }

    .no-privs {
      grid-column: 1/-1; padding: 24px;
      text-align: center; font-size: 14px; color: var(--sub);
      font-style: italic;
    }

    /* ── Sticky action bar ────────────────────────────── */
    .action-wrap {
      position: fixed; bottom: 0; left: 0; right: 0;
      display: flex; justify-content: center;
      padding: 24px 24px 32px;
      background: linear-gradient(to top, var(--c) 65%, transparent);
      z-index: 100;
      pointer-events: none;
    }
    .action-bar-inner { pointer-events: auto; }

    .action-bar {
      display: inline-flex; align-items: center; gap: 10px;
      padding: 10px 10px 10px 24px;
      background: rgba(10,13,22,.95);
      backdrop-filter: blur(24px);
      border: 1px solid var(--border);
      border-radius: 60px;
      box-shadow: 0 12px 48px rgba(0,0,0,.6), 0 0 0 1px rgba(0,212,255,.06);
    }

    .ready-dot {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; color: var(--sub);
      font-family: 'JetBrains Mono', monospace;
      margin-right: 12px;
      font-weight: 500;
    }
    .ready-dot span { width:8px;height:8px;border-radius:50%;background:var(--cyan);animation:blink 2s ease infinite; }

    .btn-cancel {
      padding: 10px 20px; border-radius: 40px;
      font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 500;
      color: var(--sub); background: transparent; border: none; cursor: pointer;
      transition: color .2s, transform .2s;
    }
    .btn-cancel:hover { color: var(--txt); transform: translateX(-2px); }

    .btn-auth {
      padding: 12px 32px; border-radius: 40px;
      font-family: 'Outfit', sans-serif; font-size: 13px; font-weight: 700;
      letter-spacing: .08em; text-transform: uppercase;
      color: #fff;
      background: linear-gradient(135deg, var(--blue) 0%, var(--cyan) 100%);
      border: none; cursor: pointer;
      position: relative; overflow: hidden;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 0 20px rgba(0,212,255,.25);
    }
    .btn-auth::before {
      content:''; position:absolute; inset:0;
      background: linear-gradient(135deg, rgba(255,255,255,.18), transparent 55%);
      opacity:0; transition: opacity .2s;
    }
    .btn-auth:hover { transform: scale(1.05); box-shadow: 0 0 32px rgba(0,212,255,.45); }
    .btn-auth:hover::before { opacity:1; }
    .btn-auth:active { transform: scale(.97); }

    .btn-revoke {
      padding: 6px 14px; border-radius: 8px;
      font-size: 11px; font-weight: 700; letter-spacing: .05em;
      text-transform: uppercase; color: #ff4d4d;
      background: rgba(255, 77, 77, 0.08);
      border: 1px solid rgba(255, 77, 77, 0.2);
      cursor: pointer; transition: all .2s;
    }
    .btn-revoke:hover { background: rgba(255, 77, 77, 0.15); border-color: rgba(255, 77, 77, 0.4); transform: translateY(-1px); }

    .status-badge {
      font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; text-transform: uppercase;
      letter-spacing: .05em; margin-left: 8px; vertical-align: middle;
    }
    .status-authorized { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
    .status-pending { background: rgba(30, 107, 255, 0.1); color: var(--blue); border: 1px solid rgba(30, 107, 255, 0.2); }
    .status-not-installed { background: rgba(232, 121, 249, 0.1); color: #e879f9; border: 1px solid rgba(232, 121, 249, 0.2); }

    .success-wrap {
      min-height: 100vh; display:flex; align-items:center; justify-content:center;
      background: var(--c); font-family: 'Outfit', sans-serif;
    }
    .success-icon {
      width:80px;height:80px;border-radius:50%;margin:0 auto 28px;
      background:rgba(16,185,129,.1); border:1px solid rgba(16,185,129,.3);
      display:flex;align-items:center;justify-content:center;
      animation: pulseG 2s ease infinite;
    }
    @keyframes pulseG {
      0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,.3)}
      50%{box-shadow:0 0 0 12px rgba(16,185,129,0)}
    }
  </style>
</head>
<body>

  <div class="bg-glow"></div>

  <div class="wrap">

    <!-- ── Header ── -->
    <header class="hdr">
      <div class="logo-row">
        <div class="logo-badge">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
            <polygon points="10,1 18,5.5 18,14.5 10,19 2,14.5 2,5.5"
              fill="none" stroke="url(#lg)" stroke-width="1.4"/>
            <defs>
              <linearGradient id="lg" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#00d4ff"/>
                <stop offset="100%" stop-color="#1e6bff"/>
              </linearGradient>
            </defs>
            <path d="M7 10l2 2 4-4" stroke="#00d4ff" stroke-width="1.3"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <span class="logo-name">XFPM</span>
      </div>
      <h1>{{if .IsReview}}Plugin Review{{else}}Plugin Verification{{end}}</h1>
      <p>Review and authorize privileges for each plugin<br>before they become active on your system.</p>
      <div class="hdr-divider"></div>
    </header>

    <!-- ── Plugin list ── -->
    <form id="vform">

      <!-- count pill -->
      <div style="text-align:center;margin-bottom:18px;">
        <span class="count-pill">
          <span class="count-dot"></span>
          {{len .Plugins}} plugin(s) {{if .IsReview}}under review{{else}}pending{{end}}
        </span>
      </div>

      {{range $i, $p := .Plugins}}
      <div class="plugin-card{{if ne .Status "authorized"}} pending-card{{end}}" id="card-{{.Name}}">

        <!-- top row -->
        <div class="card-top">
          <div class="avatar">{{slice .Name 0 1}}</div>
          <div class="card-meta">
            <div class="card-name">
              {{.Name}}
              <span id="status-badge-{{.Name}}">
              {{if eq .Status "authorized"}}
                <span class="status-badge status-authorized">Authorized</span>
              {{else if eq .Status "NOT_INSTALLED"}}
                <span class="status-badge status-not-installed">Not Installed</span>
              {{else}}
                <span class="status-badge status-pending">Pending</span>
              {{end}}
              </span>
            </div>
            <div class="card-dev">
              <span class="dev-label">DEV</span>
              <span class="dev-id">{{.Identity}}</span>
            </div>
          </div>
          <div class="trust-wrap" id="action-wrap-{{.Name}}">
            {{if eq .Status "authorized"}}
            <button type="button" class="btn-revoke" onclick="showRevokeModal('{{.Name}}')">Revoke</button>
            {{end}}
            
            {{if eq .Status "NOT_INSTALLED"}}
              <button type="button" class="btn-install" id="install-btn-{{.Name}}" onclick="installPlugin('{{.Name}}', '{{.Version}}')">Install</button>
            {{else}}
              <span class="trust-lbl">Trust</span>
              <label class="toggle">
                <input type="checkbox" id="trust-{{.Name}}" name="trust-{{.Name}}" {{if or (eq .Status "authorized") (not $.IsReview)}}checked{{end}} />
                <span class="tslider"></span>
              </label>
            {{end}}
          </div>
        </div>

        <!-- privileges -->
        <div class="privs">
          <div class="privs-label">Requested privileges</div>
          <div class="priv-grid">
            {{range .RequestedPrivileges}}
            <label class="priv-item">
              <input type="checkbox" name="perm-{{$p.Name}}-{{.ID}}" class="xchk" {{if .Approved}}checked{{end}} />
              <div class="priv-body">
                <div class="priv-name">{{.Name}}</div>
                <div class="priv-desc">{{.Description}}</div>
                <span class="priv-id">{{.ID}}</span>
              </div>
            </label>
            {{else}}
            <div class="no-privs">No special privileges requested.</div>
            {{end}}
          </div>
        </div>

      </div>
      {{end}}

      <!-- ── Action bar ── -->
      <div class="action-wrap">
        <div class="action-bar-inner">
          <div class="action-bar">
            <div class="ready-dot"><span></span>ready</div>
            <button type="button" class="btn-cancel" onclick="doCancel()">Cancel</button>
            <button type="submit" class="btn-auth">{{if .IsReview}}Update Configuration{{else}}Authorize Selected{{end}}</button>
          </div>
        </div>
      </div>

    </form>
  </div><!-- /wrap -->

  <!-- Revoke Modal -->
  <div id="revoke-modal">
    <div class="modal-box">
      <div class="modal-title">Revoke Trust</div>
      <div class="modal-desc" id="revoke-desc">Are you sure you want to revoke trust for this plugin? It will be removed from authorized plugins.</div>
      
      <div class="modal-opts">
        <label class="modal-opt">
          <input type="radio" name="revoke-opt" value="false" checked>
          <div>Move to pending list<span>Keeps the installation but requires re-authorization.</span></div>
        </label>
        <label class="modal-opt">
          <input type="radio" name="revoke-opt" value="true">
          <div>Completely uninstall (--no-pending)<span>Physically uninstalls the plugin and breaks symlinks.</span></div>
        </label>
      </div>

      <div class="modal-actions">
        <button type="button" class="btn-modal-cancel" onclick="closeRevokeModal()">Cancel</button>
        <button type="button" class="btn-modal-confirm" id="btn-confirm-revoke">Revoke</button>
      </div>
    </div>
  </div>

  <script>
    let pluginToRevoke = null;

    document.getElementById('vform').onsubmit = async (e) => {
      e.preventDefault();
      const result = {};
      for (const [k, v] of new FormData(e.target).entries()) result[k] = v;

      try {
        const r = await fetch('/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(result)
        });
        if (r.ok) {
          document.body.innerHTML = `
            <div class="success-wrap">
              <div style="text-align:center;animation:fadeUp .45s ease both">
                <div class="success-icon">
                  <svg width="26" height="26" fill="none" stroke="#10b981" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <h2 style="font-size:20px;font-weight:800;margin-bottom:6px;color:#dde6f0;">Configuration updated</h2>
                <p style="font-size:13px;color:#4e6280;">You can now return to your terminal.</p>
              </div>
            </div>
            <style>@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}</style>
          `;
          setTimeout(() => window.close(), 2500);
        }
      } catch (err) { alert('Error: ' + err); }
    };

    function doCancel() {
      if (confirm('Cancel plugin management?'))
        fetch('/cancel', { method: 'POST' }).then(() => window.close());
    }

    function showRevokeModal(name) {
      pluginToRevoke = name;
      document.getElementById('revoke-desc').innerText = `Are you sure you want to revoke trust for "${name}"? It will be removed from authorized plugins.`;
      document.getElementById('revoke-modal').style.display = 'flex';
      // Reset radios
      document.querySelector('input[name="revoke-opt"][value="false"]').checked = true;
    }

    function closeRevokeModal() {
      document.getElementById('revoke-modal').style.display = 'none';
      pluginToRevoke = null;
    }

    async function installPlugin(name, version) {
      if (!confirm(`Do you want to fetch and install "${name}@${version}"?`)) return;
      const btn = document.getElementById('install-btn-' + name);
      if(btn) { btn.innerText = 'Installing...'; btn.disabled = true; }

      try {
        const body = new URLSearchParams();
        body.append('package', name);
        body.append('version', version);

        const r = await fetch('/install', { method: 'POST', body: body });
        if (r.ok) {
          const wrap = document.getElementById('action-wrap-' + name);
          if (wrap) {
            wrap.innerHTML = `
              <span class="trust-lbl">Trust</span>
              <label class="toggle">
                <input type="checkbox" id="trust-${name}" name="trust-${name}" />
                <span class="tslider"></span>
              </label>
            `;
          }
          const card = document.querySelector('.plugin-card input[name="trust-' + name + '"]').closest('.plugin-card');
          if (card) {
            const nameEl = card.querySelector('.card-name');
            nameEl.innerHTML = name + ' <span class="status-badge status-pending">Pending</span>';
          }
        } else {
          alert('Failed to install plugin. Server returned: ' + r.status + '\\n' + await r.text());
          if(btn) { btn.innerText = 'Install'; btn.disabled = false; }
        }
      } catch(e) {
        alert('Install error: ' + e);
        if(btn) { btn.innerText = 'Install'; btn.disabled = false; }
      }
    }

    document.getElementById('btn-confirm-revoke').onclick = async () => {
      if (!pluginToRevoke) return;
      const noPending = document.querySelector('input[name="revoke-opt"]:checked').value === "true";
      
      const name = pluginToRevoke;
      const btn = document.getElementById('btn-confirm-revoke');
      const originalText = btn.innerText;
      btn.innerText = 'Revoking...';
      btn.style.pointerEvents = 'none';

      try {
        const body = new URLSearchParams();
        body.append('package', name);
        body.append('noPending', noPending);
        
        const r = await fetch('/revoke', {
          method: 'POST',
          body: body
        });
        
        if (r.ok) {
          closeRevokeModal();
          const toggle = document.getElementById('trust-' + name);
          if (toggle) toggle.checked = false;
          
          const card = document.querySelector('.plugin-card input[name="trust-' + name + '"]').closest('.plugin-card');
          if (card) {
            card.style.opacity = '0.4';
            card.style.filter = 'grayscale(1)';
            card.style.pointerEvents = 'none';
            const nameEl = card.querySelector('.card-name');
            nameEl.innerHTML = name + ' <span class="status-badge status-pending" style="background: rgba(255, 77, 77, 0.1); color: #ff4d4d; border-color: rgba(255, 77, 77, 0.2);">Revoked</span>';
          }
        } else {
          alert('Revocation failed. Server returned: ' + r.status);
        }
      } catch(e) {
        alert('Failed to revoke plugin: ' + e);
      } finally {
        btn.innerText = originalText;
        btn.style.pointerEvents = 'auto';
        closeRevokeModal();
      }
    };

    // Real-time synchronization
    const es = new EventSource('/events');
    es.onmessage = (e) => {
      try {
        const plugins = JSON.parse(e.data);
        updateDashboard(plugins);
      } catch (err) { console.error('SSE Error:', err); }
    };

    function updateDashboard(plugins) {
      plugins.forEach(p => {
        // Update Card Class
        const card = document.getElementById('card-' + p.name);
        if (card) {
          if (p.status === 'authorized') card.classList.remove('pending-card');
          else card.classList.add('pending-card');
        }

        // Update Badge
        const badgeWrap = document.getElementById('status-badge-' + p.name);
        if (badgeWrap) {
          let html = '';
          if (p.status === 'authorized') html = '<span class="status-badge status-authorized">Authorized</span>';
          else if (p.status === 'NOT_INSTALLED') html = '<span class="status-badge status-not-installed">Not Installed</span>';
          else html = '<span class="status-badge status-pending">Pending</span>';
          badgeWrap.innerHTML = html;
        }

        // Update Action Wrap
        const actionWrap = document.getElementById('action-wrap-' + p.name);
        if (actionWrap) {
          let html = '';
          if (p.status === 'authorized') {
            html += `<button type="button" class="btn-revoke" onclick="showRevokeModal('${p.name}')">Revoke</button>`;
          }
          
          if (p.status === 'NOT_INSTALLED') {
            html += `<button type="button" class="btn-install" id="install-btn-${p.name}" onclick="installPlugin('${p.name}', '${p.version}')">Install</button>`;
          } else {
            const isChecked = (p.status === 'authorized' || !{{.IsReview}});
            html += `
              <span class="trust-lbl">Trust</span>
              <label class="toggle">
                <input type="checkbox" id="trust-${p.name}" name="trust-${p.name}" ${isChecked ? 'checked' : ''} />
                <span class="tslider"></span>
              </label>
            `;
          }
          actionWrap.innerHTML = html;
        }
      });
    }
  </script>
</body>
</html>
