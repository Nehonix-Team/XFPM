<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XFPM Security Audit — {{.ProjectName}}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <style>
        :root {
            --bg: #080c14;
            --surface: #0d1421;
            --surface2: #111927;
            --border: #1e2d45;
            --border2: #243550;
            --text: #e2eaf5;
            --muted: #4a6080;
            --accent: #38bdf8;
            --accent2: #34d399;
            --danger: #f87171;
            --danger2: #dc2626;
            --warn: #fbbf24;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Syne', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }
        code, pre, .mono { font-family: 'JetBrains Mono', monospace; }

        body::before {
            content: '';
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            opacity: 0.4;
        }

        .wrap { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 2rem 1.5rem; }

        .header-glow {
            background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(56,189,248,0.12) 0%, transparent 70%);
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            display: flex; flex-direction: column; gap: 0.25rem;
            transition: border-color 0.2s, transform 0.2s;
        }
        .stat-card:hover { border-color: var(--border2); transform: translateY(-2px); }

        #graph-canvas {
            width: 100%; height: 480px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            position: relative;
            transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        #graph-canvas.expanded { height: 85vh; }
        #graph-canvas svg { width: 100%; height: 100%; }
        .node-root circle { fill: #1d4ed8; stroke: #3b82f6; stroke-width: 2; }
        .node-vuln circle { fill: #7f1d1d; stroke: #ef4444; stroke-width: 2.5; }
        .node-normal circle { fill: #0f2240; stroke: #1e3a5f; stroke-width: 1.5; }
        .node text { font-size: 10px; fill: #e2eaf5; font-family: 'JetBrains Mono', monospace; font-weight: 600; pointer-events: none; text-shadow: 0 1px 4px rgba(0,0,0,0.8); }
        .link { stroke: #1e3a5f; stroke-opacity: 0.6; }
        .link-vuln { stroke: #7f1d1d; stroke-opacity: 0.8; }
        .graph-tooltip {
            position: absolute; background: #0d1421; border: 1px solid #1e2d45;
            border-radius: 8px; padding: 0.5rem 0.75rem; font-size: 12px;
            font-family: 'JetBrains Mono', monospace; pointer-events: none;
            white-space: nowrap; z-index: 10; opacity: 0; transition: opacity 0.15s;
            box-shadow: 0 4px 24px rgba(0,0,0,0.5);
        }
        .graph-legend {
            position: absolute; bottom: 12px; left: 16px;
            display: flex; gap: 1rem; align-items: center;
        }
        .legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: #64748b; }
        .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

        .vuln-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            cursor: pointer;
            transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
            position: relative; overflow: hidden;
        }
        .vuln-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(90deg, #dc2626, #f87171);
            opacity: 0; transition: opacity 0.2s;
        }
        .vuln-card:hover { border-color: #ef444433; transform: translateY(-3px); box-shadow: 0 12px 40px rgba(239,68,68,0.08); }
        .vuln-card:hover::before { opacity: 1; }
        .cve-badge {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px; font-weight: 600;
            background: rgba(239,68,68,0.12); color: #f87171;
            border: 1px solid rgba(239,68,68,0.25);
            padding: 3px 8px; border-radius: 4px; letter-spacing: 0.05em;
            display: inline-block;
        }

        #modal-overlay {
            position: fixed; inset: 0; z-index: 100;
            background: rgba(4, 8, 16, 0.92);
            backdrop-filter: blur(8px);
            display: none; align-items: center; justify-content: center;
            padding: 1rem;
        }
        #modal-overlay.active { display: flex; }
        #modal-box {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: 20px;
            width: 100%; max-width: 900px;
            max-height: 92vh;
            display: flex; flex-direction: column;
            box-shadow: 0 0 0 1px rgba(56,189,248,0.05), 0 32px 80px rgba(0,0,0,0.6);
            animation: modal-in 0.2s ease;
        }
        @keyframes modal-in {
            from { opacity: 0; transform: scale(0.96) translateY(8px); }
            to   { opacity: 1; transform: scale(1) translateY(0); }
        }
        #modal-header {
            padding: 1.5rem 2rem 1.25rem;
            border-bottom: 1px solid var(--border);
            display: flex; justify-content: space-between; align-items: flex-start;
            flex-shrink: 0;
        }
        #modal-body {
            overflow-y: auto; padding: 1.5rem 2rem 2rem;
            flex: 1;
        }
        #modal-body::-webkit-scrollbar { width: 6px; }
        #modal-body::-webkit-scrollbar-track { background: transparent; }
        #modal-body::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
        .close-btn {
            width: 32px; height: 32px; border-radius: 8px;
            background: var(--surface2); border: 1px solid var(--border);
            color: var(--muted); cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: all 0.15s; flex-shrink: 0;
        }
        .close-btn:hover { background: var(--border); color: var(--text); }

        .md-content { font-size: 0.9rem; line-height: 1.8; color: #cbd5e1; }
        .md-content h1,.md-content h2,.md-content h3 { color: var(--text); font-weight: 700; margin: 1.25em 0 0.5em; }
        .md-content h1 { font-size: 1.3em; }
        .md-content h2 { font-size: 1.1em; }
        .md-content h3 { font-size: 1em; }
        .md-content p { margin: 0.6em 0; }
        .md-content ul, .md-content ol { margin: 0.6em 0; padding-left: 1.5em; }
        .md-content li { margin: 0.25em 0; }
        .md-content code {
            background: rgba(56,189,248,0.08); color: #7dd3fc;
            padding: 1px 6px; border-radius: 4px; font-size: 0.88em;
        }
        .md-content pre {
            background: #060a12; border: 1px solid var(--border);
            border-radius: 10px; padding: 1rem; overflow-x: auto; margin: 0.75em 0;
        }
        .md-content pre code { background: none; color: inherit; padding: 0; font-size: 0.85em; }
        .md-content blockquote {
            border-left: 3px solid var(--accent); padding-left: 1rem;
            color: var(--muted); margin: 0.75em 0;
        }
        .md-content a { color: var(--accent); text-decoration: underline; }
        .md-content strong { color: var(--text); }
        .md-content table { width: 100%; border-collapse: collapse; margin: 0.75em 0; }
        .md-content th { background: var(--surface2); padding: 0.5rem 0.75rem; text-align: left; font-size: 0.85em; border: 1px solid var(--border); }
        .md-content td { padding: 0.5rem 0.75rem; border: 1px solid var(--border); font-size: 0.85em; }
        .md-content hr { border: none; border-top: 1px solid var(--border); margin: 1em 0; }

        .sev-badge {
            font-family: 'JetBrains Mono', monospace; font-size: 11px;
            padding: 4px 10px; border-radius: 6px; display: inline-block;
        }
        .sev-badge.critical { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.3); }
        .sev-badge.high     { background: rgba(251,146,60,0.15); color: #fb923c; border: 1px solid rgba(251,146,60,0.3); }
        .sev-badge.medium   { background: rgba(251,191,36,0.12); color: #fbbf24; border: 1px solid rgba(251,191,36,0.25); }
        .sev-badge.low      { background: rgba(52,211,153,0.1);  color: #34d399; border: 1px solid rgba(52,211,153,0.2); }

        .section-label {
            font-size: 11px; letter-spacing: 0.12em; font-weight: 600;
            color: var(--muted); text-transform: uppercase; margin-bottom: 1rem;
        }

        .graph-controls {
            position: absolute; top: 12px; right: 12px;
            display: flex; gap: 6px; z-index: 5;
        }
        .graph-btn {
            background: rgba(13,20,33,0.9); border: 1px solid var(--border);
            color: var(--muted); padding: 4px 10px; border-radius: 6px;
            font-size: 11px; cursor: pointer; transition: all 0.15s;
            font-family: 'JetBrains Mono', monospace;
        }
        .graph-btn:hover { border-color: var(--accent); color: var(--accent); }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

        @keyframes fade-up {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up  { animation: fade-up 0.4s ease forwards; }
        .delay-1  { animation-delay: 0.1s; opacity: 0; }
        .delay-2  { animation-delay: 0.2s; opacity: 0; }
        .delay-3  { animation-delay: 0.3s; opacity: 0; }
        .delay-4  { animation-delay: 0.4s; opacity: 0; }
    </style>
</head>
<body>

<!-- Modal -->
<div id="modal-overlay">
    <div id="modal-box">
        <div id="modal-header">
            <div>
                <div class="cve-badge" id="modal-cve" style="margin-bottom:8px"></div>
                <div style="font-size:1.4rem;font-weight:800;color:#f1f5f9;margin-top:6px" id="modal-title"></div>
                <div style="font-size:0.85rem;color:#4a6080;margin-top:4px;font-family:'JetBrains Mono',monospace" id="modal-pkg-ver"></div>
            </div>
            <button class="close-btn" id="close-modal">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
        </div>
        <div id="modal-body">
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:1.5rem">
                <div style="background:#060a12;border:1px solid #1e2d45;border-radius:10px;padding:12px">
                    <div class="section-label">Package</div>
                    <div style="color:#38bdf8;font-family:'JetBrains Mono',monospace;font-size:0.9rem;font-weight:600" id="m-pkg"></div>
                </div>
                <div style="background:#060a12;border:1px solid #1e2d45;border-radius:10px;padding:12px">
                    <div class="section-label">Version</div>
                    <div style="color:#fbbf24;font-family:'JetBrains Mono',monospace;font-size:0.9rem;font-weight:600" id="m-ver"></div>
                </div>
                <div style="background:#060a12;border:1px solid #1e2d45;border-radius:10px;padding:12px">
                    <div class="section-label">Severity</div>
                    <div id="m-sev"></div>
                </div>
            </div>
            <div class="section-label">Advisory Details</div>
            <div id="modal-details" class="md-content"></div>

            <div class="section-label" style="margin-top:2rem">Pulled in by</div>
            <div id="modal-paths" class="md-content" style="font-family:'JetBrains Mono',monospace;font-size:0.8rem;background:#060a12;border:1px solid #1e2d45;border-radius:10px;padding:1rem;color:#94a3b8"></div>
            <div style="margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid #1e2d45;display:flex;justify-content:flex-end">
                <a id="modal-link" href="#" target="_blank"
                   style="color:#38bdf8;font-size:0.85rem;font-family:'JetBrains Mono',monospace;text-decoration:none;border:1px solid #1e3a5f;padding:6px 14px;border-radius:8px;transition:all 0.15s"
                   onmouseover="this.style.background='#0f2240'" onmouseout="this.style.background='transparent'">
                    View on OSV →
                </a>
            </div>
        </div>
    </div>
</div>

<div class="wrap">
    <!-- Header -->
    <header class="header-glow fade-up" style="padding:2.5rem 0 2rem;margin-bottom:2.5rem;border-bottom:1px solid #1e2d45">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem">
            <div>
                <div style="font-size:11px;letter-spacing:0.15em;color:#1e6091;text-transform:uppercase;font-weight:600;margin-bottom:8px">Nehonix XFPM</div>
                <h1 style="font-size:2.5rem;font-weight:800;background:linear-gradient(135deg,#e2eaf5 0%,#38bdf8 60%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1.1">Security Audit Report</h1>
                <p style="color:#4a6080;margin-top:8px;font-size:0.9rem">
                    Project: <span style="color:#38bdf8;font-family:'JetBrains Mono',monospace">{{.ProjectName}}</span>
                    <span style="margin:0 8px;color:#1e2d45">|</span>
                    Generated: <span style="font-family:'JetBrains Mono',monospace">{{.GeneratedAt}}</span>
                </p>
            </div>
            <div style="text-align:right">
                <div style="background:rgba(220,38,38,0.1);border:1px solid rgba(220,38,38,0.25);border-radius:12px;padding:12px 20px;display:inline-block">
                    <div style="font-size:2rem;font-weight:800;color:#f87171">{{.VulnCount}}</div>
                    <div style="font-size:11px;color:#ef444488;letter-spacing:0.1em;text-transform:uppercase">Vulnerabilities</div>
                </div>
            </div>
        </div>
    </header>

    <!-- Stats row -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2.5rem" class="fade-up delay-1">
        <div class="stat-card">
            <div style="font-size:11px;letter-spacing:0.1em;color:#4a6080;text-transform:uppercase">Total Packages</div>
            <div style="font-size:2rem;font-weight:800;color:#38bdf8;font-family:'JetBrains Mono',monospace">{{.TotalPackages}}</div>
        </div>
        <div class="stat-card">
            <div style="font-size:11px;letter-spacing:0.1em;color:#4a6080;text-transform:uppercase">Vulnerabilities</div>
            <div style="font-size:2rem;font-weight:800;color:#f87171;font-family:'JetBrains Mono',monospace">{{.VulnCount}}</div>
        </div>
        <div class="stat-card">
            <div style="font-size:11px;letter-spacing:0.1em;color:#4a6080;text-transform:uppercase">Vuln Rate</div>
            <div style="font-size:2rem;font-weight:800;color:#fbbf24;font-family:'JetBrains Mono',monospace">{{.VulnRate}}%</div>
        </div>
        <div class="stat-card">
            <div style="font-size:11px;letter-spacing:0.1em;color:#4a6080;text-transform:uppercase">Source</div>
            <div style="font-size:2rem;font-weight:800;color:#34d399;font-family:'JetBrains Mono',monospace">OSV</div>
        </div>
    </div>
    
  <!-- Vulnerability Cards -->
    <div style="margin-bottom:3rem" class="fade-up delay-3">
        <div class="section-label" style="margin-bottom:1.25rem">Vulnerability Details</div>
        <div id="vuln-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:1.25rem"></div>
    </div>

    <!-- Dependency Graph -->
    <div style="margin-bottom:2.5rem" class="fade-up delay-2">
        <div class="section-label">Dependency Graph</div>
        <div id="graph-canvas">
            <div class="graph-tooltip" id="graph-tooltip"></div>
            <div class="graph-controls">
                <button class="graph-btn" id="expand-btn" onclick="toggleExpand()">Expand</button>
                <button class="graph-btn" onclick="resetZoom()">Reset</button>
                <button class="graph-btn" onclick="toggleLabels()">Labels</button>
            </div>
            <div class="graph-legend">
                <div class="legend-item"><div class="legend-dot" style="background:#3b82f6;border:2px solid #60a5fa"></div>Root</div>
                <div class="legend-item"><div class="legend-dot" style="background:#7f1d1d;border:2px solid #ef4444"></div>Vulnerable</div>
                <div class="legend-item"><div class="legend-dot" style="background:#1e3a5f;border:1px solid #2d5a8f"></div>Package</div>
            </div>
        </div>
    </div>

    <footer style="text-align:center;color:#1e3a5f;font-size:0.8rem;border-top:1px solid #0d1421;padding-top:2rem;margin-top:2rem;font-family:'JetBrains Mono',monospace" class="fade-up delay-4">
        XFPM Runtime Security Engine · Nehonix Team © 2026
    </footer>
</div>

<script id="vulns-data" type="application/json">{{.VulnsJSON}}</script>
<script id="graph-data" type="application/json">{{.GraphJSON}}</script>

<script>
const VULNS = JSON.parse(document.getElementById('vulns-data').textContent);
const GRAPH = JSON.parse(document.getElementById('graph-data').textContent);
let showLabels = false; // Start with labels off for better clarity
let isExpanded = false;
let svgRoot, simulation, zoomBehavior;

// ─── Render vuln cards ───
const grid = document.getElementById('vuln-grid');
VULNS.forEach(v => {
    const card = document.createElement('div');
    card.className = 'vuln-card';
    const sev = v.Severity || '';
    const sc = sevClass(sev);
    card.innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px">
            <span class="cve-badge">${v.ID}</span>
            <span style="font-size:11px;font-family:'JetBrains Mono',monospace;color:#4a6080">${v.Version}</span>
        </div>
        <div style="font-size:1.05rem;font-weight:700;color:#e2eaf5;margin-bottom:6px">${v.Package}</div>
        <p style="color:#4a6080;font-size:0.85rem;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">${v.Summary || 'No summary provided.'}</p>
        <div style="margin-top:14px;padding-top:12px;border-top:1px solid #1e2d45;display:flex;justify-content:space-between;align-items:center">
            <span class="sev-badge ${sc}">${sev || 'UNKNOWN'}</span>
            <span style="color:#38bdf8;font-size:12px;font-weight:600">Details →</span>
        </div>
    `;
    card.onclick = () => openModal(v);
    grid.appendChild(card);
});

// ─── Severity helper ───
function sevClass(s) {
    if (!s) return 'low';
    if (s.includes('9') || s.includes('10')) return 'critical';
    if (s.includes('7') || s.includes('8'))  return 'high';
    if (s.includes('4') || s.includes('5') || s.includes('6')) return 'medium';
    return 'low';
}

// ─── Modal ───
function openModal(v) {
    document.getElementById('modal-cve').textContent     = v.ID;
    document.getElementById('modal-title').textContent   = v.Package;
    document.getElementById('modal-pkg-ver').textContent = v.Package + ' @ ' + v.Version;
    document.getElementById('m-pkg').textContent         = v.Package;
    document.getElementById('m-ver').textContent         = v.Version;
    document.getElementById('m-sev').innerHTML           = `<span class="sev-badge ${sevClass(v.Severity)}">${v.Severity || 'UNKNOWN'}</span>`;
    document.getElementById('modal-link').href           = 'https://osv.dev/vulnerability/' + v.ID;

    const raw = v.Details || v.Summary || 'No detailed information available.';
    document.getElementById('modal-details').innerHTML   = marked.parse(raw);
    document.querySelectorAll('#modal-details pre code').forEach(el => hljs.highlightElement(el));

    // Render paths
    const pathContainer = document.getElementById('modal-paths');
    pathContainer.innerHTML = '';
    if (v.Paths && v.Paths.length > 0) {
        v.Paths.forEach(path => {
            const pDiv = document.createElement('div');
            pDiv.style.marginBottom = '8px';
            pDiv.style.display = 'flex';
            pDiv.style.alignItems = 'center';
            pDiv.style.flexWrap = 'wrap';
            pDiv.style.gap = '4px';
            
            path.forEach((node, idx) => {
                const nodeSpan = document.createElement('span');
                nodeSpan.textContent = node;
                if (node === '[root]') nodeSpan.style.color = '#3b82f6';
                else if (idx === path.length - 1) nodeSpan.style.color = '#f87171';
                else nodeSpan.style.color = '#e2eaf5';
                
                pDiv.appendChild(nodeSpan);
                if (idx < path.length - 1) {
                    const arrow = document.createElement('span');
                    arrow.textContent = '→';
                    arrow.style.color = '#4a6080';
                    arrow.style.margin = '0 2px';
                    pDiv.appendChild(arrow);
                }
            });
            pathContainer.appendChild(pDiv);
        });
    } else {
        pathContainer.textContent = 'No dependency path available.';
    }

    document.getElementById('modal-overlay').classList.add('active');
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('modal-overlay').classList.remove('active');
    document.body.style.overflow = '';
}

document.getElementById('close-modal').addEventListener('click', closeModal);
document.getElementById('modal-overlay').addEventListener('click', e => {
    if (e.target === document.getElementById('modal-overlay')) closeModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

// ─── D3 Force Graph ───
function buildGraph() {
    const container = document.getElementById('graph-canvas');
    const W = container.clientWidth, H = container.clientHeight;
    const vulnIds = new Set(VULNS.map(v => v.Package));

    const nodes = GRAPH.nodes.map(d => ({...d}));
    const links = GRAPH.edges.map(d => ({source: d.source, target: d.target}));

    const svg = d3.select('#graph-canvas').append('svg')
        .attr('width', W).attr('height', H);
    svgRoot = svg;

    svg.append('defs').append('marker')
        .attr('id', 'arrow').attr('viewBox', '0 -4 8 8')
        .attr('refX', 14).attr('refY', 0)
        .attr('markerWidth', 4).attr('markerHeight', 4)
        .attr('orient', 'auto')
      .append('path').attr('d', 'M0,-4L8,0L0,4').attr('fill', '#1e3a5f');

    const g = svg.append('g');
    zoomBehavior = d3.zoom().scaleExtent([0.1, 6]).on('zoom', e => g.attr('transform', e.transform));
    svg.call(zoomBehavior);

    simulation = d3.forceSimulation(nodes)
        .force('link',      d3.forceLink(links).id(d => d.id).distance(100).strength(0.5))
        .force('charge',    d3.forceManyBody().strength(-400))
        .force('center',    d3.forceCenter(W / 2, H / 2))
        .force('collision', d3.forceCollide(30));

    const link = g.append('g').selectAll('line')
        .data(links).join('line')
        .attr('class', d => {
            const src = typeof d.source === 'object' ? d.source.name : d.source;
            return vulnIds.has(src) ? 'link link-vuln' : 'link';
        })
        .attr('stroke-width', 1)
        .attr('marker-end', 'url(#arrow)');

    const node = g.append('g').selectAll('g')
        .data(nodes).join('g')
        .attr('class', d => d.isRoot ? 'node-root' : (d.vuln ? 'node-vuln' : 'node-normal'))
        .call(d3.drag()
            .on('start', (e, d) => { if (!e.active) simulation.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
            .on('drag',  (e, d) => { d.fx = e.x; d.fy = e.y; })
            .on('end',   (e, d) => { if (!e.active) simulation.alphaTarget(0); d.fx = null; d.fy = null; }));

    node.append('circle').attr('r', d => d.isRoot ? 14 : (d.vuln ? 10 : 6));

    node.append('text')
        .attr('dy', d => d.isRoot ? 20 : 15)
        .attr('text-anchor', 'middle')
        .text(d => d.isRoot ? 'root' : (d.name.length > 16 ? d.name.slice(0, 14) + '…' : d.name));

    const tooltip = document.getElementById('graph-tooltip');
    node.on('mouseenter', (e, d) => {
        tooltip.style.opacity = '1';
        tooltip.innerHTML = `<span style="color:#38bdf8">${d.name}</span><span style="color:#4a6080"> @${d.version}</span>` +
                            (d.vuln ? ` <span style="color:#f87171">⚠ vulnerable</span>` : '');
        tooltip.style.left = (e.offsetX + 14) + 'px';
        tooltip.style.top  = (e.offsetY - 10) + 'px';
    }).on('mousemove', e => {
        tooltip.style.left = (e.offsetX + 14) + 'px';
        tooltip.style.top  = (e.offsetY - 10) + 'px';
    }).on('mouseleave', () => { tooltip.style.opacity = '0'; });

    node.on('click', (e, d) => {
        if (d.vuln) {
            const v = VULNS.find(x => x.Package === d.name);
            if (v) openModal(v);
        }
    });

    simulation.on('tick', () => {
        link.attr('x1', d => d.source.x).attr('y1', d => d.source.y)
            .attr('x2', d => d.target.x).attr('y2', d => d.target.y);
        node.attr('transform', d => `translate(${d.x},${d.y})`);
    });
}

function resetZoom()   { svgRoot && svgRoot.transition().duration(500).call(zoomBehavior.transform, d3.zoomIdentity); }
function toggleLabels() {
    showLabels = !showLabels;
    d3.selectAll('.node-root text, .node-vuln text, .node-normal text').style('display', showLabels ? null : 'none');
}

function toggleExpand() {
    isExpanded = !isExpanded;
    const canvas = document.getElementById('graph-canvas');
    const btn = document.getElementById('expand-btn');
    if (isExpanded) {
        canvas.classList.add('expanded');
        btn.textContent = 'Shrink';
    } else {
        canvas.classList.remove('expanded');
        btn.textContent = 'Expand';
    }
    // Update simulation center
    setTimeout(() => {
        const W = canvas.clientWidth, H = canvas.clientHeight;
        simulation.force('center', d3.forceCenter(W / 2, H / 2)).alpha(0.3).restart();
    }, 350);
}

buildGraph();
</script>
</body>
</html>
