  "github": `<svg xmlns="http://www.w3.org/2000/svg" width="ICONSIZE" height="ICONSIZE" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
  "file-type": `<svg xmlns="http://www.w3.org/2000/svg" width="ICONSIZE" height="ICONSIZE" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 13v-1h6v1"/><path d="M11 18h2"/><path d="M12 12v6"/></svg>`,
  "file-question": `<svg xmlns="http://www.w3.org/2000/svg" width="ICONSIZE" height="ICONSIZE" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9.1 9a3 3 0 0 1 5.82 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>`,
};

function getIcon(name, size) {
    size = size || 20;
    const svg = (ICON_SVG[name] || ICON_SVG['file']).replace(/ICONSIZE/g, size);
    return svg;
}


/* Render icon into an element */
function setIcon(el, name, size) {
    if (el) el.innerHTML = getIcon(name, size || 18);
}

/* ============================================================
   INIT STATIC ICONS
   ============================================================ */
setIcon(document.getElementById('headerServerIcon'), 'server', 20);
setIcon(document.getElementById('iconSun'), 'sun', 18);
setIcon(document.getElementById('iconMoon'), 'moon', 18);
setIcon(document.getElementById('iconHome'), 'home', 16);
setIcon(document.getElementById('iconSearch'), 'search', 18);
setIcon(document.getElementById('iconLoaderSearch'), 'loader-2', 18);
setIcon(document.getElementById('iconLoaderViewer'), 'loader-2', 30);
setIcon(document.getElementById('iconDownloadBtn'), 'download', 18);
setIcon(document.getElementById('iconCloseBtn'), 'x', 18);
setIcon(document.getElementById('iconUnsupportedWrap'), 'file-question', 38);
setIcon(document.getElementById('iconDownloadUnsupported'), 'download', 16);

/* ============================================================
   THEME
   ============================================================ */
const htmlEl = document.documentElement;

function setTheme(dark) {
    htmlEl.setAttribute('data-theme', dark ? 'dark' : 'light');
    document.getElementById('iconSun').classList.toggle('hide', !dark);
    document.getElementById('iconMoon').classList.toggle('hide', dark);
    try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch(e) {}
}

// Init theme
(function() {
    let saved;
    try { saved = localStorage.getItem('theme'); } catch(e) {}
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    setTheme(saved === 'dark' || (!saved && prefersDark));
})();

document.getElementById('themeToggle').addEventListener('click', () => {
    setTheme(htmlEl.getAttribute('data-theme') !== 'dark');
});

/* ============================================================
   FILE ICON HELPERS
   ============================================================ */
const ICON_COLOR_VARS = {
    // directories
    '.git': '--ic-orange', '.github': '--ic-orange',
    'node_modules': '--ic-green',
    'src': '--ic-blue', 'lib': '--ic-blue', 'source': '--ic-blue',
    'assets': '--ic-pink', 'public': '--ic-pink', 'images': '--ic-pink',
    'test': '--ic-yellow', 'tests': '--ic-yellow',
    'bin': '--ic-cyan', 'build': '--ic-cyan', 'dist': '--ic-cyan', 'out': '--ic-cyan',
    'cmd': '--ic-slate', 'scripts': '--ic-slate',
    'docs': '--ic-purple', 'doc': '--ic-purple',
    // file extensions
    'js': '--ic-yellow', 'ts': '--ic-yellow', 'jsx': '--ic-yellow', 'tsx': '--ic-yellow',
    'go': '--ic-cyan', 'py': '--ic-blue', 'java': '--ic-orange',
    'html': '--ic-orange', 'css': '--ic-blue',
    'json': '--ic-green', 'md': '--ic-slate', 'txt': '--ic-slate',
    'png': '--ic-pink', 'jpg': '--ic-pink', 'jpeg': '--ic-pink', 'gif': '--ic-pink', 'svg': '--ic-pink', 'webp': '--ic-pink',
    'mp4': '--ic-purple', 'webm': '--ic-purple',
    'zip': '--ic-red', 'tar': '--ic-red', 'gz': '--ic-red', 'rar': '--ic-red',
    'pdf': '--ic-red',
    'xfpm': '--ic-xfpm', 'lock': '--ic-xfpm',
    'mp3': '--ic-purple', 'wav': '--ic-purple', 'flac': '--ic-purple', 'aac': '--ic-purple',
};

function getIconForFile(name, isDir) {
    const low = name.toLowerCase();
    if (isDir) {
        // XFPM folder detection: starts with . and ends with .xfpm, or just .xfpm dirs
        if (low.endsWith('.xfpm') || low === '.xfpm') return 'xfpm-folder';
        const dirMap = {
            '.git': 'git-branch', '.github': 'github',
            'node_modules': 'package',
            'src': 'folder-code', 'lib': 'folder-code', 'source': 'folder-code',
            'assets': 'image', 'public': 'image', 'images': 'image',
            'bin': 'box', 'build': 'box', 'dist': 'box', 'out': 'box',
            'cmd': 'terminal', 'scripts': 'terminal',
            'docs': 'book', 'doc': 'book',
            'test': 'flask-conical', 'tests': 'flask-conical',
        };
        return dirMap[low] || 'folder';
    }
    // XFPM lock file: *.xfpm.resolve.lock or *.xfpm.lock or *.lock with xfpm
    if (low.includes('.xfpm') || (low.endsWith('.lock') && low.includes('xfpm'))) return 'xfpm-lock';
    const ext = low.split('.').pop();
    const extMap = {
        'json': 'braces',
        'js': 'file-code-2', 'ts': 'file-code-2', 'jsx': 'file-code-2', 'tsx': 'file-code-2',
        'go': 'file-code', 'py': 'file-code', 'java': 'file-code', 'c': 'file-code', 'cpp': 'file-code', 'rs': 'file-code',
        'html': 'file-type', 'xml': 'file-type',
        'css': 'paintbrush',
        'md': 'file-text', 'txt': 'file-text',
        'pdf': 'file-pdf',
        'png': 'image', 'jpg': 'image', 'jpeg': 'image', 'gif': 'image', 'svg': 'image', 'webp': 'image',
        'mp4': 'video', 'webm': 'video', 'mkv': 'video', 'avi': 'video',
        'mp3': 'music', 'wav': 'music', 'ogg': 'music', 'flac': 'music', 'aac': 'music',
        'zip': 'archive', 'tar': 'archive', 'gz': 'archive', 'rar': 'archive',
    };
    return extMap[ext] || 'file';
}

function getIconColor(name, isDir) {
    const low = name.toLowerCase();
    if (isDir) {
        if (low.endsWith('.xfpm') || low === '.xfpm') return '--ic-xfpm';
        return ICON_COLOR_VARS[low] || '--ic-primary';
    }
    if (low.includes('.xfpm') || (low.endsWith('.lock') && low.includes('xfpm'))) return '--ic-xfpm';
    const key = low.split('.').pop();
    return ICON_COLOR_VARS[key] || '--ic-muted';
}

/* ============================================================
   FORMAT BYTES
   ============================================================ */
function formatBytes(bytes) {
    if (!+bytes) return '0 B';
    const k = 1024;
    const sizes = ['B','KB','MB','GB','TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return (bytes / Math.pow(k, i)).toFixed(i === 0 ? 0 : 1) + ' ' + sizes[i];
}

/* ============================================================
   STATE & ELEMENTS
   ============================================================ */
let currentDir = '';
let searchTimeout = null;

const fileList = document.getElementById('fileList');
const emptyState = document.getElementById('emptyState');
const breadcrumbsEl = document.getElementById('breadcrumbs');
const searchInput = document.getElementById('searchInput');
const searchLoader = document.getElementById('searchLoader');
const viewerOverlay = document.getElementById('viewerOverlay');
const viewerTitle = document.getElementById('viewerTitle');
const viewerLoader = document.getElementById('viewerLoader');
const viewerCodeWrap = document.getElementById('viewerCodeWrap');
const viewerCode = document.getElementById('viewerCode');
const viewerMarkdown = document.getElementById('viewerMarkdown');
const viewerMedia = document.getElementById('viewerMedia');
const viewerImage = document.getElementById('viewerImage');
const viewerVideo = document.getElementById('viewerVideo');
const viewerUnsupported = document.getElementById('viewerUnsupported');
const viewerDownloadBtn = document.getElementById('viewerDownloadBtn');
const viewerDownloadLink = document.getElementById('viewerDownloadLink');
const modalIconSlot = document.getElementById('modalIconSlot');

/* ============================================================
   BREADCRUMBS
   ============================================================ */
function renderBreadcrumbs() {
    breadcrumbsEl.innerHTML = '';
    if (!currentDir) return;
    const parts = currentDir.split('/').filter(Boolean);
    let path = '';
    parts.forEach((part, i) => {
        path += (path ? '/' : '') + part;
        const sep = document.createElement('span');
        sep.className = 'breadcrumb-sep';
        sep.innerHTML = getIcon('chevron-right', 14);
        breadcrumbsEl.appendChild(sep);
        if (i === parts.length - 1) {
            const span = document.createElement('span');
            span.className = 'breadcrumb-current';
            span.textContent = part;
            breadcrumbsEl.appendChild(span);
        } else {
            const btn = document.createElement('button');
            btn.className = 'breadcrumb-btn';
            btn.textContent = part;
            const p = path;
            btn.onclick = () => navigateTo(p);
            breadcrumbsEl.appendChild(btn);
        }
    });
}

/* ============================================================
   RENDER FILES
   ============================================================ */
function renderFiles(list) {
    fileList.innerHTML = '';
    if (!list || list.length === 0) {
        emptyState.classList.add('visible');
        setIcon(document.getElementById('iconEmptyWrap'), 'folder-search', 38);
        return;
    }
    emptyState.classList.remove('visible');
    list.sort((a, b) => {
        if (a.IsDir && !b.IsDir) return -1;
        if (!a.IsDir && b.IsDir) return 1;
        return a.Name.localeCompare(b.Name);
    });
    list.forEach(f => {
        const iconName = getIconForFile(f.Name, f.IsDir);
        const colorVar = getIconColor(f.Name, f.IsDir);
        const sizeStr = f.IsDir ? '—' : formatBytes(f.Size);
        const tr = document.createElement('tr');
        // Name cell
        const tdName = document.createElement('td');
        tdName.className = 'col-name';
        const inner = document.createElement('div');
        inner.className = 'file-row-inner';
        const iconWrap = document.createElement('div');
        iconWrap.className = 'file-icon-wrap';
        iconWrap.style.color = 'var(' + colorVar + ')';
        iconWrap.innerHTML = getIcon(iconName, 18);
        inner.appendChild(iconWrap);
        const nameDiv = document.createElement('div');
        // Show path prefix for search results
        if (f.Path && f.Path !== f.Name && f.Path !== currentDir + '/' + f.Name) {
            const prefix = f.Path.substring(0, f.Path.lastIndexOf('/'));
            if (prefix) {
                const prefixSpan = document.createElement('span');
                prefixSpan.className = 'file-path-prefix';
                prefixSpan.textContent = prefix + '/';
                nameDiv.appendChild(prefixSpan);
            }
        }
        const nameSpan = document.createElement('span');
        nameSpan.className = 'file-name';
        nameSpan.textContent = f.Name;
        nameDiv.appendChild(nameSpan);
        inner.appendChild(nameDiv);
        tdName.appendChild(inner);
        // Size cell
        const tdSize = document.createElement('td');
        tdSize.className = 'col-size';
        tdSize.textContent = sizeStr;
        tr.appendChild(tdName);
        tr.appendChild(tdSize);
        tr.onclick = () => f.IsDir ? navigateTo(f.Path) : openViewer(f.Name, f.Path);
        fileList.appendChild(tr);
    });
}

/* ============================================================
   FETCH
   ============================================================ */
async function fetchFiles(dir) {
    try {
        const res = await fetch('/api/files?dir=' + encodeURIComponent(dir || ''));
        const data = await res.json();
        renderFiles(data);
    } catch (e) {
        console.error('fetchFiles error', e);
    }
}

async function doSearch(q) {
    if (!q) { fetchFiles(currentDir); return; }
    searchLoader.classList.add('visible');
    try {
        const res = await fetch('/api/search?q=' + encodeURIComponent(q));
        const data = await res.json();
        renderFiles(data);
    } catch(e) {
        console.error('search error', e);
    } finally {
        searchLoader.classList.remove('visible');
    }
}

/* ============================================================
   NAVIGATE
   ============================================================ */
function navigateTo(dir, push) {
    currentDir = dir;
    searchInput.value = '';
    renderBreadcrumbs();
    fetchFiles(dir);
    if (push !== false) {
        const u = new URL(window.location.href);
        dir ? u.searchParams.set('dir', dir) : u.searchParams.delete('dir');
        history.pushState({ dir }, '', u);
    }
}

window.addEventListener('popstate', e => navigateTo(e.state ? e.state.dir : '', false));
searchInput.addEventListener('input', e => {
    const q = e.target.value.trim();
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => doSearch(q), 300);
});

/* ============================================================
   VIEWER
   ============================================================ */
const CODE_EXTS = new Set(['js','ts','jsx','tsx','go','py','java','c','cpp','rs','json','html','css','xml','yaml','yml','sh','bash','rb','php','swift','kt','cs','txt']);
const MD_EXTS = new Set(['md','markdown']);
const IMG_EXTS = new Set(['png','jpg','jpeg','gif','svg','webp']);
const VID_EXTS = new Set(['mp4','webm']);
const AUD_EXTS = new Set(['mp3','wav','ogg','flac','aac','m4a']);
const PDF_EXTS = new Set(['pdf']);

/* PDF state */
let pdfDoc = null, pdfCurrentPage = 1, pdfScale = 1.4;
const PDF_SCALES = [0.5, 0.75, 1.0, 1.25, 1.4, 1.75, 2.0, 2.5, 3.0];

function viewerReset() {
    viewerLoader.classList.remove('hidden');
    viewerCodeWrap.classList.remove('visible');
    viewerMarkdown.classList.remove('visible');
    viewerMedia.classList.remove('visible');
    viewerUnsupported.classList.remove('visible');
    document.getElementById('viewerPdf').classList.remove('visible');
    viewerImage.style.display = 'none';
    viewerVideo.style.display = 'none';
    viewerVideo.pause();
    viewerVideo.removeAttribute('src');
    const aw = document.getElementById('viewerAudioWrap');
    if (aw) { aw.style.display = 'none'; }
    const va = document.getElementById('viewerAudio');
    if (va) { va.pause(); va.removeAttribute('src'); }
    if (pdfDoc) { pdfDoc.destroy(); pdfDoc = null; }
    pdfCurrentPage = 1;
    pdfScale = 1.4;
    document.getElementById('pdfCanvasWrap').innerHTML = '';
    document.getElementById('pdfFallback').classList.remove('visible');
}

async function openViewer(name, path) {
    viewerReset();
    const iconName = getIconForFile(name, false);
    const colorVar = getIconColor(name, false);
    modalIconSlot.innerHTML = getIcon(iconName, 18);
    modalIconSlot.style.color = 'var(' + colorVar + ')';
    viewerTitle.textContent = name;
    const rawUrl = '/raw/' + path;
    viewerDownloadBtn.href = rawUrl;
    viewerDownloadLink.href = rawUrl;
    document.body.style.overflow = 'hidden';
    viewerOverlay.classList.add('open');
    const ext = name.split('.').pop().toLowerCase();
    await new Promise(r => setTimeout(r, 150));
    try {
        if (IMG_EXTS.has(ext)) {
            viewerImage.src = rawUrl;
            viewerImage.style.display = '';
            viewerMedia.classList.add('visible');
            viewerLoader.classList.add('hidden');
        } else if (VID_EXTS.has(ext)) {
            viewerVideo.src = rawUrl;
            viewerVideo.style.display = '';
            viewerMedia.classList.add('visible');
            viewerLoader.classList.add('hidden');
        } else if (AUD_EXTS.has(ext)) {
            const aw = document.getElementById('viewerAudioWrap');
            const va = document.getElementById('viewerAudio');
            const ai = document.getElementById('viewerAudioIcon');
            const an = document.getElementById('viewerAudioName');
            va.src = rawUrl;
            if (ai) { ai.innerHTML = getIcon('music', 36); }
            if (an) { an.textContent = name; }
            aw.style.display = 'flex';
            viewerMedia.classList.add('visible');
            viewerLoader.classList.add('hidden');
        } else if (PDF_EXTS.has(ext)) {
            await openPdfViewer(rawUrl);
        } else if (MD_EXTS.has(ext)) {
            const res = await fetch(rawUrl);
            const text = await res.text();
            viewerMarkdown.innerHTML = marked.parse(text);
            viewerMarkdown.querySelectorAll('pre code').forEach(b => hljs.highlightElement(b));
            viewerMarkdown.classList.add('visible');
            viewerLoader.classList.add('hidden');
        } else if (CODE_EXTS.has(ext)) {
            const res = await fetch(rawUrl);
            const text = await res.text();
            viewerCode.className = ext !== 'txt' ? 'language-' + ext : '';
            viewerCode.textContent = text;
            if (ext !== 'txt') hljs.highlightElement(viewerCode);
            viewerCodeWrap.classList.add('visible');
            viewerLoader.classList.add('hidden');
        } else {
            viewerUnsupported.classList.add('visible');
            viewerLoader.classList.add('hidden');
        }
    } catch(e) {
        viewerUnsupported.classList.add('visible');
        viewerLoader.classList.add('hidden');
    }
}

/* ============================================================
   PDF VIEWER ENGINE (pdf.js CDN loaded lazily on first PDF open)
   We load pdf.js from a bundled minimal worker approach:
   - pdf.js is fetched from embedded blob on first use
   - All pages rendered to <canvas> elements
   ============================================================ */

let pdfJsLib = null;

async function loadPdfJs() {
    if (pdfJsLib) return pdfJsLib;
    // We embed a minimal pdf.js loader — uses the official CDN build
    // but only fetched ONCE and cached in memory for this session
    // If offline and not cached yet, falls back gracefully
    return new Promise((resolve) => {
        if (window.pdfjsLib) { pdfJsLib = window.pdfjsLib; resolve(pdfJsLib); return; }
        const script = document.createElement('script');
        // Try to load pdf.js — if it fails (offline), we show fallback
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.min.mjs';
        script.type = 'module';
        script.onload = () => { pdfJsLib = window.pdfjsLib; resolve(pdfJsLib); };
        script.onerror = () => resolve(null);
        document.head.appendChild(script);
    });
}

async function renderPdfPage(page, scale, container) {
    const viewport = page.getViewport({ scale });
    const canvas = document.createElement('canvas');
    canvas.className = 'pdf-page-canvas';
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    container.appendChild(canvas);
    const ctx = canvas.getContext('2d');
    await page.render({ canvasContext: ctx, viewport }).promise;
    return canvas;
}

async function pdfRenderAllPages() {
    if (!pdfDoc) return;
    const wrap = document.getElementById('pdfCanvasWrap');
    wrap.innerHTML = '';
    const total = pdfDoc.numPages;
    for (let i = 1; i <= total; i++) {
        const page = await pdfDoc.getPage(i);
        await renderPdfPage(page, pdfScale, wrap);
    }
    document.getElementById('pdfPageInfo').textContent = total + ' page' + (total > 1 ? 's' : '');
}

async function openPdfViewer(url) {
    const pdfPanel = document.getElementById('viewerPdf');
    const fallback = document.getElementById('pdfFallback');

    // Init toolbar icon buttons
    setIcon(document.getElementById('iconPdfPrev'), 'chevron-left', 14);
    setIcon(document.getElementById('iconPdfNext'), 'chevron-right', 14);
    setIcon(document.getElementById('iconZoomOut'), 'zoom-out', 14);
    setIcon(document.getElementById('iconZoomIn'), 'zoom-in', 14);
    setIcon(document.getElementById('iconPdfFallbackDl'), 'download', 16);

    // Show panel
    pdfPanel.classList.add('visible');

    // Try to use pdfjsLib if already on window
    let lib = window.pdfjsLib || null;

    if (!lib) {
        // Try dynamic import of pdf.js mjs
        try {
            const mod = await import('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.min.mjs');
            lib = mod;
        } catch(e) { lib = null; }
    }

    if (!lib) {
        // Truly offline fallback — show open link
        document.getElementById('pdfFallbackLink').href = url;
        fallback.classList.add('visible');
        viewerLoader.classList.add('hidden');
        return;
    }

    // Set worker
    try {
        lib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.worker.min.mjs';
    } catch(e) {}

    try {
        const loadingTask = lib.getDocument(url);
        pdfDoc = await loadingTask.promise;
        const total = pdfDoc.numPages;
        const wrap = document.getElementById('pdfCanvasWrap');
        wrap.innerHTML = '';
        document.getElementById('pdfPageInfo').textContent = '0 / ' + total;

        // Render all pages progressively
        for (let i = 1; i <= total; i++) {
            const page = await pdfDoc.getPage(i);
            const viewport = page.getViewport({ scale: pdfScale });
            const canvas = document.createElement('canvas');
            canvas.className = 'pdf-page-canvas';
            canvas.width = viewport.width;
            canvas.height = viewport.height;
            canvas.dataset.page = i;
            wrap.appendChild(canvas);
            const ctx = canvas.getContext('2d');
            await page.render({ canvasContext: ctx, viewport }).promise;
            document.getElementById('pdfPageInfo').textContent = i + ' / ' + total;
            if (i === 1) viewerLoader.classList.add('hidden');
        }
        document.getElementById('pdfPageInfo').textContent = total + ' page' + (total > 1 ? 's' : '');

        // Zoom controls
        const zoomLabel = document.getElementById('pdfZoomLabel');
        document.getElementById('pdfZoomIn').onclick = async () => {
            const next = PDF_SCALES.find(s => s > pdfScale);
            if (!next) return;
            pdfScale = next;
            zoomLabel.textContent = Math.round(pdfScale * 100) + '%';
            await rerenderPdf();
        };
        document.getElementById('pdfZoomOut').onclick = async () => {
            const prev = [...PDF_SCALES].reverse().find(s => s < pdfScale);
            if (!prev) return;
            pdfScale = prev;
            zoomLabel.textContent = Math.round(pdfScale * 100) + '%';
            await rerenderPdf();
        };
        zoomLabel.textContent = Math.round(pdfScale * 100) + '%';

        // Scroll-based page indicator
        wrap.addEventListener('scroll', () => {
            const canvases = wrap.querySelectorAll('.pdf-page-canvas');
            let current = 1;
            canvases.forEach(c => {
                if (c.offsetTop - wrap.scrollTop < wrap.clientHeight / 2) {
                    current = parseInt(c.dataset.page) || current;
                }
            });
            document.getElementById('pdfPageInfo').textContent = current + ' / ' + total;
        }, { passive: true });

    } catch(e) {
        document.getElementById('pdfFallbackLink').href = url;
        fallback.classList.add('visible');
        viewerLoader.classList.add('hidden');
    }
}

async function rerenderPdf() {
    if (!pdfDoc) return;
    const wrap = document.getElementById('pdfCanvasWrap');
    const total = pdfDoc.numPages;
    const canvases = wrap.querySelectorAll('.pdf-page-canvas');
    for (let i = 1; i <= total; i++) {
        const canvas = canvases[i - 1];
        if (!canvas) continue;
        const page = await pdfDoc.getPage(i);
        const viewport = page.getViewport({ scale: pdfScale });
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        const ctx = canvas.getContext('2d');
        await page.render({ canvasContext: ctx, viewport }).promise;
    }
}

function closeViewer() {
    viewerOverlay.classList.remove('open');
    viewerVideo.pause();
    document.body.style.overflow = '';
    setTimeout(() => viewerReset(), 300);
}

viewerOverlay.addEventListener('click', e => { if (e.target === viewerOverlay) closeViewer(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape' && viewerOverlay.classList.contains('open')) closeViewer(); });

/* ============================================================
   INIT
   ============================================================ */
(function() {
    const initDir = new URLSearchParams(window.location.search).get('dir') || '';
    history.replaceState({ dir: initDir }, '', window.location.href);
    navigateTo(initDir, false);
})();
</script>
</body>
</html>