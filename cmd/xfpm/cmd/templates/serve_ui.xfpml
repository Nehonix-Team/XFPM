<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XFPM File Server</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Highlight.js for Code Highlighting -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" id="hljs-theme">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <!-- Marked.js for Markdown -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff', 100: '#dbeafe', 200: '#bfdbfe', 300: '#93c5fd', 400: '#60a5fa', 500: '#3b82f6',
                            600: '#2563eb', 700: '#1d4ed8', 800: '#1e40af', 900: '#1e3a8a', 950: '#172554',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Glassmorphism & Themes */
        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }
        .dark .glass {
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        
        body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        
        .hide { display: none !important; }
        
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .dark ::-webkit-scrollbar-thumb { background: #475569; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .dark ::-webkit-scrollbar-thumb:hover { background: #64748b; }

        /* Markdown Styles */
        .markdown-body h1, .markdown-body h2, .markdown-body h3 { font-weight: bold; margin-top: 1.5em; margin-bottom: 0.5em; }
        .markdown-body h1 { font-size: 2em; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.3em; }
        .dark .markdown-body h1 { border-bottom-color: #334155; }
        .markdown-body h2 { font-size: 1.5em; }
        .markdown-body h3 { font-size: 1.25em; }
        .markdown-body p { margin-bottom: 1em; line-height: 1.6; }
        .markdown-body code { background: #f1f5f9; padding: 0.2em 0.4em; border-radius: 4px; font-family: monospace; font-size: 0.9em; }
        .dark .markdown-body code { background: #1e293b; }
        .markdown-body pre { background: #1e293b !important; padding: 1em; border-radius: 8px; overflow-x: auto; margin-bottom: 1em; }
        .markdown-body pre code { background: transparent; padding: 0; color: #f8fafc; }
        .markdown-body a { color: #3b82f6; text-decoration: none; }
        .markdown-body a:hover { text-decoration: underline; }
        .markdown-body ul { list-style-type: disc; padding-left: 2em; margin-bottom: 1em; }
        .markdown-body ol { list-style-type: decimal; padding-left: 2em; margin-bottom: 1em; }
        .markdown-body blockquote { border-left: 4px solid #cbd5e1; padding-left: 1em; color: #64748b; margin-bottom: 1em; }
        .dark .markdown-body blockquote { border-left-color: #475569; color: #94a3b8; }
        .markdown-body img { max-width: 100%; border-radius: 8px; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-slate-50 antialiased font-sans h-screen flex flex-col overflow-hidden">
    
    <!-- Top Bar -->
    <header class="flex-none glass z-40 px-6 py-4 flex items-center justify-between shadow-sm border-b border-slate-200 dark:border-slate-800">
        <div class="flex items-center gap-3">
            <div class="p-2 bg-primary-500/10 dark:bg-primary-500/20 rounded-xl">
                <i data-lucide="server" class="w-6 h-6 text-primary-600 dark:text-primary-400"></i>
            </div>
            <h1 class="text-xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-primary-600 to-indigo-600 dark:from-primary-400 dark:to-indigo-400">XFPM Serve</h1>
        </div>
        
        <button id="themeToggle" class="p-2.5 rounded-full hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-400" title="Toggle Theme">
            <i data-lucide="sun" class="w-5 h-5 hidden dark:block"></i>
            <i data-lucide="moon" class="w-5 h-5 block dark:hidden"></i>
        </button>
    </header>

    <main class="flex-1 overflow-y-auto w-full relative" id="appMain">
        <div class="w-full max-w-6xl mx-auto p-4 sm:p-6 lg:p-8 flex flex-col gap-6">
            <!-- Controls Area -->
            <div class="flex flex-col sm:flex-row items-center gap-4">
                
                <!-- Breadcrumbs -->
                <div class="flex-1 w-full flex items-center bg-white dark:bg-slate-900 rounded-2xl px-5 py-4 shadow-sm border border-slate-200 dark:border-slate-800 overflow-x-auto whitespace-nowrap scrollbar-hide">
                    <button class="text-slate-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors font-medium flex items-center gap-2" onclick="navigateTo('')">
                        <i data-lucide="home" class="w-4 h-4"></i> Root
                    </button>
                    <span id="breadcrumbs" class="flex items-center font-medium text-slate-700 dark:text-slate-300"></span>
                </div>

                <!-- Search -->
                <div class="relative w-full sm:w-80 flex-shrink-0">
                    <i data-lucide="search" class="w-5 h-5 absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    <input type="text" id="searchInput" class="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl pl-12 pr-4 py-4 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all placeholder-slate-400 shadow-sm" placeholder="Search recursively...">
                    <div id="searchLoader" class="absolute right-4 top-1/2 -translate-y-1/2 hide">
                        <i data-lucide="loader-2" class="w-5 h-5 text-primary-500 animate-spin"></i>
                    </div>
                </div>
            </div>

            <!-- File List -->
            <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 dark:text-slate-400 text-sm font-semibold uppercase tracking-wider border-b border-slate-200 dark:border-slate-800">
                            <th class="py-4 px-6 w-full">Name</th>
                            <th class="py-4 px-6 w-32 text-right">Size</th>
                        </tr>
                    </thead>
                    <tbody id="fileList" class="divide-y divide-slate-100 dark:divide-slate-800">
                        <!-- Rendered by JS -->
                    </tbody>
                </table>
                <div id="emptyState" class="hide flex flex-col items-center justify-center py-24 text-slate-400 dark:text-slate-500">
                    <div class="p-4 bg-slate-50 dark:bg-slate-800 rounded-full mb-4">
                        <i data-lucide="folder-search" class="w-10 h-10"></i>
                    </div>
                    <p class="text-lg font-medium">No files found.</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Viewer Overlay (Modal) -->
    <div id="viewerOverlay" class="hide fixed inset-0 z-50 flex items-center justify-center bg-slate-900/40 dark:bg-slate-900/80 backdrop-blur-sm opacity-0 transition-opacity duration-300 p-4 sm:p-8">
        <div class="bg-white dark:bg-slate-900 w-full max-w-5xl h-full max-h-[90vh] rounded-3xl shadow-2xl flex flex-col overflow-hidden border border-slate-200 dark:border-slate-700 transform scale-95 transition-transform duration-300" id="viewerModalContent">
            
            <!-- Modal Header -->
            <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-slate-50 dark:bg-slate-800/50">
                <h2 class="font-semibold text-slate-800 dark:text-slate-200 truncate pr-4 flex items-center gap-3 text-lg" id="viewerTitle">
                    <i data-lucide="file" class="w-5 h-5 text-slate-400"></i> File
                </h2>
                <div class="flex items-center gap-1">
                    <a id="viewerDownloadBtn" href="#" download class="p-2 text-slate-500 hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors" title="Download File">
                        <i data-lucide="download" class="w-5 h-5"></i>
                    </a>
                    <button onclick="closeViewer()" class="p-2 text-slate-500 hover:text-red-500 dark:text-slate-400 dark:hover:text-red-400 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-xl transition-colors" title="Close">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
            
            <!-- Modal Body -->
            <div class="flex-1 overflow-y-auto bg-white dark:bg-slate-950 p-6 relative" id="viewerContainer">
                <div id="viewerLoader" class="absolute inset-0 flex items-center justify-center bg-white/80 dark:bg-slate-950/80 z-10 backdrop-blur-sm">
                    <div class="flex flex-col items-center gap-3">
                        <i data-lucide="loader-2" class="w-8 h-8 text-primary-500 animate-spin"></i>
                        <span class="text-sm font-medium text-slate-500">Loading content...</span>
                    </div>
                </div>
                
                <!-- Code / Text Content -->
                <pre id="viewerCodeContainer" class="hide h-full m-0"><code id="viewerCode" class="h-full rounded-xl text-sm font-mono p-4"></code></pre>
                
                <!-- Markdown Content -->
                <div id="viewerMarkdown" class="hide markdown-body max-w-4xl mx-auto"></div>
                
                <!-- Media Content -->
                <div class="flex items-center justify-center min-h-full">
                    <img id="viewerImage" class="max-w-full rounded-xl shadow-lg hide" />
                    <video id="viewerVideo" class="max-w-full rounded-xl shadow-lg hide outline-none" controls></video>
                </div>
                
                <!-- Unsupported File -->
                <div id="viewerUnsupported" class="hide flex flex-col items-center justify-center min-h-full text-slate-500 dark:text-slate-400">
                    <div class="p-6 bg-slate-50 dark:bg-slate-800 rounded-full mb-6">
                        <i data-lucide="file-question" class="w-16 h-16 opacity-50"></i>
                    </div>
                    <p class="text-xl font-medium">Cannot preview this file type natively.</p>
                    <a id="viewerDownloadLink" href="#" target="_blank" class="mt-4 px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white font-medium rounded-xl transition-colors inline-flex items-center gap-2 shadow-sm shadow-primary-500/20">
                        <i data-lucide="download" class="w-4 h-4"></i> Download File
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // Theme Handling
        const themeToggleBtn = document.getElementById('themeToggle');
        const htmlEl = document.documentElement;
        const hljsThemeLink = document.getElementById('hljs-theme');
        
        function setTheme(isDark) {
            if (isDark) {
                htmlEl.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                hljsThemeLink.href = 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css';
            } else {
                htmlEl.classList.remove('dark');
                localStorage.setItem('theme', 'light');
                hljsThemeLink.href = 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-light.min.css';
            }
        }
        
        // Init theme
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            setTheme(true);
        } else {
            setTheme(false);
        }

        themeToggleBtn.addEventListener('click', () => {
            setTheme(!htmlEl.classList.contains('dark'));
        });

        // State
        let currentDir = '';
        let files = [];
        let searchTimeout = null;

        // Elements
        const fileList = document.getElementById('fileList');
        const searchInput = document.getElementById('searchInput');
        const emptyState = document.getElementById('emptyState');
        const breadcrumbsEl = document.getElementById('breadcrumbs');
        const searchLoader = document.getElementById('searchLoader');
        
        const viewerOverlay = document.getElementById('viewerOverlay');
        const viewerModalContent = document.getElementById('viewerModalContent');
        const viewerTitle = document.getElementById('viewerTitle');
        const viewerCodeContainer = document.getElementById('viewerCodeContainer');
        const viewerCode = document.getElementById('viewerCode');
        const viewerMarkdown = document.getElementById('viewerMarkdown');
        const viewerImage = document.getElementById('viewerImage');
        const viewerVideo = document.getElementById('viewerVideo');
        const viewerUnsupported = document.getElementById('viewerUnsupported');
        const viewerLoader = document.getElementById('viewerLoader');
        const viewerDownloadBtn = document.getElementById('viewerDownloadBtn');
        const viewerDownloadLink = document.getElementById('viewerDownloadLink');

        function getIconForFile(name, isDir) {
            const lowerName = name.toLowerCase();
            if (isDir) {
                switch (lowerName) {
                    case '.git': return 'git-branch';
                    case 'node_modules': return 'package';
                    case 'src': case 'source': case 'lib': return 'folder-code';
                    case 'assets': case 'public': case 'images': return 'image';
                    case 'bin': case 'build': case 'dist': case 'out': return 'box';
                    case 'cmd': case 'scripts': return 'terminal';
                    case 'docs': case 'doc': return 'book';
                    case 'test': case 'tests': return 'flask-conical';
                    case '.github': return 'github';
                    default: return 'folder';
                }
            }
            const ext = name.split('.').pop().toLowerCase();
            switch (ext) {
                case 'json': return 'braces';
                case 'js': case 'ts': case 'jsx': case 'tsx': return 'file-code-2';
                case 'go': case 'py': case 'java': case 'c': case 'cpp': case 'rs': return 'file-code';
                case 'html': case 'xml': return 'file-type';
                case 'css': return 'paintbrush';
                case 'md': case 'txt': return 'file-text';
                case 'png': case 'jpg': case 'jpeg': case 'gif': case 'svg': case 'webp': return 'image';
                case 'mp4': case 'webm': case 'mkv': case 'avi': return 'video';
                case 'mp3': case 'wav': case 'ogg': return 'audio-lines';
                case 'zip': case 'tar': case 'gz': case 'rar': return 'archive';
                case 'pdf': return 'file-text';
                default: return 'file';
            }
        }

        function getIconColor(name, isDir) {
            const lowerName = name.toLowerCase();
            if (isDir) {
                switch (lowerName) {
                    case '.git': case '.github': return 'text-orange-500';
                    case 'node_modules': return 'text-green-600';
                    case 'src': case 'lib': return 'text-blue-500';
                    case 'assets': case 'public': return 'text-pink-500';
                    case 'test': case 'tests': return 'text-yellow-500';
                    case 'bin': case 'build': case 'dist': return 'text-cyan-600';
                    case 'cmd': case 'scripts': return 'text-slate-500 dark:text-slate-400';
                    case 'docs': return 'text-purple-500';
                    default: return 'text-primary-500';
                }
            }
            const ext = name.split('.').pop().toLowerCase();
            switch (ext) {
                case 'js': case 'ts': case 'jsx': case 'tsx': return 'text-yellow-500';
                case 'go': return 'text-cyan-500';
                case 'py': return 'text-blue-500';
                case 'html': return 'text-orange-500';
                case 'css': return 'text-blue-400';
                case 'json': return 'text-green-500';
                case 'md': return 'text-slate-500 dark:text-slate-400';
                case 'png': case 'jpg': case 'jpeg': case 'svg': return 'text-pink-500';
                case 'mp4': case 'webm': return 'text-purple-500';
                case 'zip': case 'tar': return 'text-red-500';
                default: return 'text-slate-400';
            }
        }

        function formatBytes(bytes, decimals = 2) {
            if (!+bytes) return '0 B';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
        }

        function renderBreadcrumbs() {
            if (!currentDir) {
                breadcrumbsEl.innerHTML = '';
                return;
            }
            const parts = currentDir.split('/').filter(Boolean);
            let path = '';
            breadcrumbsEl.innerHTML = '';
            
            parts.forEach((part, index) => {
                path += (path ? '/' : '') + part;
                const isLast = index === parts.length - 1;
                
                const sep = document.createElement('span');
                sep.className = "mx-3 text-slate-300 dark:text-slate-600";
                sep.innerHTML = '<i data-lucide="chevron-right" class="w-4 h-4"></i>';
                breadcrumbsEl.appendChild(sep);

                if (isLast) {
                    const span = document.createElement('span');
                    span.className = "text-primary-600 dark:text-primary-400 font-bold";
                    span.textContent = part;
                    breadcrumbsEl.appendChild(span);
                } else {
                    const btn = document.createElement('button');
                    btn.className = "hover:text-primary-600 dark:hover:text-primary-400 transition-colors cursor-pointer font-medium";
                    btn.textContent = part;
                    const clickPath = path;
                    btn.onclick = () => navigateTo(clickPath);
                    breadcrumbsEl.appendChild(btn);
                }
            });
            lucide.createIcons();
        }

        function renderFiles(list) {
            fileList.innerHTML = '';
            if (list.length === 0) {
                emptyState.classList.remove('hide');
                return;
            }
            emptyState.classList.add('hide');

            list.sort((a, b) => {
                if (a.IsDir && !b.IsDir) return -1;
                if (!a.IsDir && b.IsDir) return 1;
                return a.Name.localeCompare(b.Name);
            });

            list.forEach(f => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-colors group cursor-pointer";
                
                const iconName = getIconForFile(f.Name, f.IsDir);
                const iconColor = getIconColor(f.Name, f.IsDir);
                const sizeStr = f.IsDir ? '--' : formatBytes(f.Size);
                
                let nameDisplay = f.Name;
                if (f.Path && f.Path !== f.Name && f.Path !== currentDir + '/' + f.Name) {
                    const parent = f.Path.substring(0, f.Path.lastIndexOf('/'));
                    nameDisplay = `<span class="text-slate-400 dark:text-slate-500 text-xs mr-1">${parent}/</span><span class="font-medium">${f.Name}</span>`;
                } else {
                    nameDisplay = `<span class="font-medium text-slate-800 dark:text-slate-200">${f.Name}</span>`;
                }

                tr.innerHTML = `
                    <td class="py-4 px-6">
                        <div class="flex items-center gap-4">
                            <div class="p-2 bg-slate-100 dark:bg-slate-800 rounded-lg group-hover:bg-white dark:group-hover:bg-slate-700 transition-colors shadow-sm">
                                <i data-lucide="${iconName}" class="w-5 h-5 ${iconColor}"></i>
                            </div>
                            <div>${nameDisplay}</div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-slate-500 dark:text-slate-400 text-sm font-mono text-right">
                        ${sizeStr}
                    </td>
                `;

                tr.onclick = () => {
                    if (f.IsDir) {
                        navigateTo(f.Path);
                    } else {
                        openViewer(f.Name, f.Path);
                    }
                };
                
                fileList.appendChild(tr);
            });
            lucide.createIcons();
        }

        async function fetchFiles(dir = '') {
            try {
                const res = await fetch('/api/files?dir=' + encodeURIComponent(dir));
                const data = await res.json();
                files = data;
                renderFiles(files);
            } catch (err) {
                console.error("Failed to fetch files", err);
            }
        }

        async function doSearch(q) {
            if (!q) {
                fetchFiles(currentDir);
                return;
            }
            searchLoader.classList.remove('hide');
            try {
                const res = await fetch('/api/search?q=' + encodeURIComponent(q));
                const data = await res.json();
                renderFiles(data);
            } catch (err) {
                console.error("Search failed", err);
            } finally {
                searchLoader.classList.add('hide');
            }
        }

        function navigateTo(dir, pushState = true) {
            currentDir = dir;
            searchInput.value = '';
            renderBreadcrumbs();
            fetchFiles(dir);

            if (pushState) {
                const newUrl = new URL(window.location.href);
                if (dir) {
                    newUrl.searchParams.set('dir', dir);
                } else {
                    newUrl.searchParams.delete('dir');
                }
                window.history.pushState({ dir: dir }, '', newUrl);
            }
        }

        window.addEventListener('popstate', (e) => {
            const stateDir = e.state ? e.state.dir : '';
            navigateTo(stateDir, false);
        });

        searchInput.addEventListener('input', (e) => {
            const q = e.target.value.trim();
            if (searchTimeout) clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                doSearch(q);
            }, 300);
        });

        // Overlay Viewer Logic
        const codeExts = ['js', 'ts', 'jsx', 'tsx', 'go', 'py', 'java', 'c', 'cpp', 'rs', 'json', 'html', 'css', 'xml', 'yaml', 'yml', 'sh'];
        const markdownExts = ['md'];
        const viewableImageExts = ['png', 'jpg', 'jpeg', 'gif', 'svg', 'webp'];
        const viewableVideoExts = ['mp4', 'webm', 'ogg'];

        function openViewer(name, path) {
            // Show overlay
            viewerOverlay.classList.remove('hide');
            // Trigger animation
            setTimeout(() => {
                viewerOverlay.classList.remove('opacity-0');
                viewerOverlay.classList.add('opacity-100');
                viewerModalContent.classList.remove('scale-95');
                viewerModalContent.classList.add('scale-100');
            }, 10);
            
            viewerTitle.innerHTML = `<i data-lucide="${getIconForFile(name, false)}" class="w-5 h-5 ${getIconColor(name, false)}"></i> ${name}`;
            lucide.createIcons();

            const rawUrl = '/raw/' + path;
            viewerDownloadBtn.href = rawUrl;
            viewerDownloadLink.href = rawUrl;

            // Reset states
            viewerCodeContainer.classList.add('hide');
            viewerMarkdown.classList.add('hide');
            viewerImage.classList.add('hide');
            viewerVideo.classList.add('hide');
            viewerUnsupported.classList.add('hide');
            viewerLoader.classList.remove('hide');
            
            viewerVideo.pause();
            viewerVideo.removeAttribute('src');

            // Prevent background scrolling
            document.body.style.overflow = 'hidden';

            const ext = name.split('.').pop().toLowerCase();

            setTimeout(async () => {
                if (viewableImageExts.includes(ext)) {
                    viewerImage.src = rawUrl;
                    viewerImage.onload = () => {
                        viewerLoader.classList.add('hide');
                        viewerImage.classList.remove('hide');
                    };
                } else if (viewableVideoExts.includes(ext)) {
                    viewerVideo.src = rawUrl;
                    viewerLoader.classList.add('hide');
                    viewerVideo.classList.remove('hide');
                } else if (markdownExts.includes(ext)) {
                    try {
                        const res = await fetch(rawUrl);
                        const text = await res.text();
                        viewerMarkdown.innerHTML = marked.parse(text);
                        // Highlight code blocks inside markdown
                        viewerMarkdown.querySelectorAll('pre code').forEach((block) => {
                            hljs.highlightElement(block);
                        });
                        viewerLoader.classList.add('hide');
                        viewerMarkdown.classList.remove('hide');
                    } catch (e) {
                        showUnsupported();
                    }
                } else if (codeExts.includes(ext) || ext === 'txt') {
                    try {
                        const res = await fetch(rawUrl);
                        const text = await res.text();
                        
                        // Use highlight.js
                        viewerCode.className = 'h-full rounded-xl text-sm font-mono p-4'; // reset
                        if (ext !== 'txt') {
                            viewerCode.classList.add('language-' + ext);
                        }
                        viewerCode.textContent = text;
                        if (ext !== 'txt') {
                            hljs.highlightElement(viewerCode);
                        }
                        
                        viewerLoader.classList.add('hide');
                        viewerCodeContainer.classList.remove('hide');
                    } catch (e) {
                        showUnsupported();
                    }
                } else {
                    showUnsupported();
                }
            }, 150);
        }

        function showUnsupported() {
            viewerLoader.classList.add('hide');
            viewerUnsupported.classList.remove('hide');
        }

        function closeViewer() {
            viewerOverlay.classList.remove('opacity-100');
            viewerOverlay.classList.add('opacity-0');
            viewerModalContent.classList.remove('scale-100');
            viewerModalContent.classList.add('scale-95');
            viewerVideo.pause();
            
            // Restore background scrolling
            document.body.style.overflow = '';
            
            setTimeout(() => {
                viewerOverlay.classList.add('hide');
            }, 300);
        }

        // Close on outside click
        viewerOverlay.addEventListener('click', (e) => {
            if (e.target === viewerOverlay) {
                closeViewer();
            }
        });
        
        // Close on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !viewerOverlay.classList.contains('hide')) {
                closeViewer();
            }
        });

        // Init
        const initDir = new URLSearchParams(window.location.search).get('dir') || '';
        window.history.replaceState({ dir: initDir }, '', window.location.href);
        navigateTo(initDir, false);
    </script>
</body>
</html>
