<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XFPM File Server</title>
    <style>
        /* ========== RESET & BASE ========== */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        
        /* ========== DESIGN TOKENS ========== */
        :root {
            --bg: #f8fafc;
            --bg-card: #ffffff;
            --bg-header: rgba(255,255,255,0.80);
            --bg-table-head: #f1f5f9;
            --bg-row-hover: #eff6ff;
            --bg-icon-wrap: #f1f5f9;
            --bg-icon-wrap-hover: #ffffff;
            --bg-empty: #f8fafc;
            --bg-input: #ffffff;
            --bg-modal: #ffffff;
            --bg-modal-header: #f8fafc;
            --bg-modal-body: #ffffff;
            --bg-viewer-code: #1e293b;
            --bg-overlay: rgba(15,23,42,0.40);
            --border: #e2e8f0;
            --border-modal: #e2e8f0;
            --text: #0f172a;
            --text-muted: #64748b;
            --text-faint: #94a3b8;
            --text-head: #475569;
            --text-breadcrumb: #334155;
            --scrollbar: #cbd5e1;
            --scrollbar-hover: #94a3b8;
            --primary: #3b82f6;
            --primary-hover: #2563eb;
            --primary-bg: rgba(59,130,246,0.08);
            --primary-text: #1d4ed8;
            --primary-light: #dbeafe;
            --gradient-from: #2563eb;
            --gradient-to: #4f46e5;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.04);
            --shadow-lg: 0 20px 60px rgba(0,0,0,0.12), 0 8px 25px rgba(0,0,0,0.08);
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            --radius-xl: 20px;
            --radius-2xl: 24px;
            --transition: 0.2s ease;
            /* icon colors */
            --ic-primary: #3b82f6;
            --ic-orange: #f97316;
            --ic-green: #16a34a;
            --ic-blue: #3b82f6;
            --ic-pink: #ec4899;
            --ic-yellow: #eab308;
            --ic-cyan: #0891b2;
            --ic-purple: #a855f7;
            --ic-slate: #64748b;
            --ic-red: #ef4444;
            --ic-muted: #94a3b8;
            --ic-xfpm: #7c3aed;
        }
        
        [data-theme="dark"] {
            --bg: #020617;
            --bg-card: #0f172a;
            --bg-header: rgba(2,6,23,0.80);
            --bg-table-head: rgba(30,41,59,0.60);
            --bg-row-hover: rgba(59,130,246,0.08);
            --bg-icon-wrap: #1e293b;
            --bg-icon-wrap-hover: #334155;
            --bg-empty: #1e293b;
            --bg-input: #0f172a;
            --bg-modal: #0f172a;
            --bg-modal-header: rgba(30,41,59,0.60);
            --bg-modal-body: #020617;
            --bg-viewer-code: #1e293b;
            --bg-overlay: rgba(2,6,23,0.80);
            --border: #1e293b;
            --border-modal: #1e293b;
            --text: #f8fafc;
            --text-muted: #94a3b8;
            --text-faint: #475569;
            --text-head: #64748b;
            --text-breadcrumb: #cbd5e1;
            --scrollbar: #334155;
            --scrollbar-hover: #475569;
            --primary-bg: rgba(59,130,246,0.15);
            --primary-text: #60a5fa;
            --primary-light: rgba(59,130,246,0.10);
            --gradient-from: #60a5fa;
            --gradient-to: #818cf8;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.2);
            --shadow-lg: 0 20px 60px rgba(0,0,0,0.5), 0 8px 25px rgba(0,0,0,0.3);
        }

        /* ========== SCROLLBAR ========== */
        ::-webkit-scrollbar { width: 7px; height: 7px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--scrollbar); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-hover); }

        /* ========== LAYOUT ========== */
        html, body { height: 100%; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            font-size: 15px;
            line-height: 1.5;
            background: var(--bg);
            color: var(--text);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: background var(--transition), color var(--transition);
            -webkit-font-smoothing: antialiased;
        }

        /* ========== HEADER ========== */
        .header {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 24px;
            background: var(--bg-header);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: var(--shadow-sm);
            z-index: 40;
        }
        .header-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .header-icon-wrap {
            width: 36px; height: 36px;
            border-radius: var(--radius-md);
            background: var(--primary-bg);
            display: flex; align-items: center; justify-content: center;
            color: var(--primary-text);
        }
        .header-title {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, var(--gradient-from), var(--gradient-to));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .btn-icon {
            width: 36px; height: 36px;
            border-radius: 50%;
            border: none;
            background: transparent;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            color: var(--text-muted);
            transition: background var(--transition), color var(--transition);
        }
        .btn-icon:hover {
            background: var(--bg-icon-wrap);
            color: var(--text);
        }

        /* ========== MAIN ========== */
        main {
            flex: 1;
            overflow-y: auto;
            padding: 24px 20px;
        }
        .content-wrap {
            max-width: 960px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* ========== CONTROLS ========== */
        .controls {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
        }

        /* Breadcrumbs */
        .breadcrumb-bar {
            flex: 1;
            min-width: 0;
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 10px 18px;
            box-shadow: var(--shadow-sm);
            overflow-x: auto;
            white-space: nowrap;
        }
        .breadcrumb-bar::-webkit-scrollbar { height: 0; }
        #breadcrumbs {
            display: inline-flex;
            align-items: center;
            gap: 2px;
        }
        .btn-root {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text-muted);
            background: none;
            border: none;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            padding: 0;
            transition: color var(--transition);
        }
        .btn-root:hover { color: var(--primary-text); }
        .breadcrumb-sep {
            color: var(--text-faint);
            display: flex; align-items: center;
            flex-shrink: 0;
        }
        .breadcrumb-btn {
            background: none; border: none; cursor: pointer;
            font-size: 14px; font-weight: 500;
            color: var(--text-breadcrumb);
            padding: 0;
            transition: color var(--transition);
        }
        .breadcrumb-btn:hover { color: var(--primary-text); }
        .breadcrumb-current {
            font-size: 14px; font-weight: 700;
            color: var(--primary-text);
        }

        /* Search */
        .search-wrap {
            position: relative;
            flex-shrink: 0;
            width: 280px;
        }
        .search-icon {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            color: var(--text-faint);
            pointer-events: none;
        }
        .search-input {
            width: 100%;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 10px 42px 10px 40px;
            font-size: 14px;
            color: var(--text);
            outline: none;
            transition: border-color var(--transition), box-shadow var(--transition);
            box-shadow: var(--shadow-sm);
        }
        .search-input::placeholder { color: var(--text-faint); }
        .search-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }
        .search-loader {
            position: absolute;
            right: 14px; top: 50%;
            transform: translateY(-50%);
            color: var(--primary);
            display: none;
        }
        .search-loader.visible { display: flex; }
        @keyframes spin { to { transform: translateY(-50%) rotate(360deg); } }
        .spin { animation: spin 0.8s linear infinite; }

        /* ========== FILE TABLE ========== */
        .file-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        thead tr {
            background: var(--bg-table-head);
            border-bottom: 1px solid var(--border);
        }
        th {
            padding: 12px 20px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-head);
        }
        th.col-name { text-align: left; }
        th.col-size { text-align: right; width: 110px; }
        tbody tr {
            border-bottom: 1px solid var(--border);
            cursor: pointer;
            transition: background var(--transition);
        }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: var(--bg-row-hover); }
        td { padding: 12px 20px; }
        td.col-name { text-align: left; }
        td.col-size {
            text-align: right;
            font-family: "SF Mono", "Fira Code", monospace;
            font-size: 12px;
            color: var(--text-muted);
            width: 110px;
        }
        .file-row-inner {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .file-icon-wrap {
            width: 34px; height: 34px;
            flex-shrink: 0;
            border-radius: var(--radius-sm);
            background: var(--bg-icon-wrap);
            display: flex; align-items: center; justify-content: center;
            box-shadow: var(--shadow-sm);
            transition: background var(--transition);
        }
        tbody tr:hover .file-icon-wrap { background: var(--bg-icon-wrap-hover); }
        .file-name { font-weight: 500; color: var(--text); }
        .file-path-prefix { font-size: 12px; color: var(--text-faint); margin-right: 2px; }

        /* Empty state */
        .empty-state {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 80px 20px;
            color: var(--text-muted);
        }
        .empty-state.visible { display: flex; }
        .empty-icon-wrap {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: var(--bg-empty);
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 16px;
        }
        .empty-label { font-size: 15px; font-weight: 500; }

        /* ========== MODAL / VIEWER ========== */
        .overlay {
            display: none;
            position: fixed; inset: 0; z-index: 50;
            background: var(--bg-overlay);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            align-items: center; justify-content: center;
            padding: 24px;
            opacity: 0;
            transition: opacity 0.25s ease;
        }
        .overlay.open {
            display: flex;
            animation: fadeIn 0.25s ease forwards;
        }
        @keyframes fadeIn { to { opacity: 1; } }
        .modal {
            background: var(--bg-modal);
            border: 1px solid var(--border-modal);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-lg);
            width: 100%; max-width: 880px;
            height: 100%; max-height: 88vh;
            display: flex; flex-direction: column;
            overflow: hidden;
            transform: scale(0.96);
            animation: modalIn 0.25s ease forwards;
        }
        @keyframes modalIn { to { transform: scale(1); } }
        .modal-header {
            flex-shrink: 0;
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 20px;
            border-bottom: 1px solid var(--border);
            background: var(--bg-modal-header);
        }
        .modal-title {
            display: flex; align-items: center; gap: 10px;
            font-size: 15px; font-weight: 600;
            color: var(--text);
            overflow: hidden;
        }
        .modal-title span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .modal-actions { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
        .modal-btn {
            width: 34px; height: 34px;
            border-radius: var(--radius-sm);
            border: none; background: transparent;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            color: var(--text-muted);
            transition: background var(--transition), color var(--transition);
            text-decoration: none;
        }
        .modal-btn:hover { background: var(--bg-icon-wrap); color: var(--primary-text); }
        .modal-btn.close-btn:hover { color: #ef4444; }
        .modal-body {
            flex: 1; overflow-y: auto;
            background: var(--bg-modal-body);
            padding: 24px;
            position: relative;
        }

        /* Viewer states */
        .viewer-loader {
            position: absolute; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 10px;
            background: var(--bg-modal-body);
            z-index: 5;
        }
        .viewer-loader.hidden { display: none; }
        .loader-text { font-size: 13px; color: var(--text-muted); font-weight: 500; }
        .viewer-code-wrap {
            display: none;
            height: 100%;
        }
        .viewer-code-wrap.visible { display: block; }
        .viewer-code-wrap pre {
            background: var(--bg-viewer-code) !important;
            border-radius: var(--radius-md);
            overflow-x: auto;
            margin: 0;
            padding: 0;
        }
        .viewer-code-wrap code {
            font-family: "SF Mono","Fira Code","Fira Mono","Roboto Mono",monospace;
            font-size: 13px;
            padding: 16px !important;
            display: block;
        }
        .viewer-markdown { display: none; }
        .viewer-markdown.visible { display: block; }
        .viewer-media {
            display: none;
            min-height: 100%;
            align-items: center; justify-content: center;
        }
        .viewer-media.visible { display: flex; }
        .viewer-media img, .viewer-media video {
            max-width: 100%;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
        }
        .viewer-unsupported {
            display: none;
            min-height: 100%;
            flex-direction: column;
            align-items: center; justify-content: center;
            color: var(--text-muted);
            text-align: center;
        }
        .viewer-unsupported.visible { display: flex; }
        .unsupported-icon {
            width: 80px; height: 80px;
            border-radius: 50%;
            background: var(--bg-empty);
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 20px;
            opacity: 0.7;
        }
        .unsupported-label { font-size: 16px; font-weight: 500; margin-bottom: 16px; }
        .btn-download {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 20px;
            background: var(--primary);
            color: #ffffff;
            border-radius: var(--radius-md);
            text-decoration: none;
            font-size: 14px; font-weight: 500;
            transition: background var(--transition);
        }
        .btn-download:hover { background: var(--primary-hover); }

        /* PDF viewer */
        .viewer-pdf {
            display: none;
            flex-direction: column;
            height: 100%;
            min-height: 500px;
            gap: 0;
        }
        .viewer-pdf.visible { display: flex; }
        .pdf-toolbar {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 16px;
            background: var(--bg-table-head);
            border-bottom: 1px solid var(--border);
            border-radius: var(--radius-md) var(--radius-md) 0 0;
        }
        .pdf-toolbar-left { display: flex; align-items: center; gap: 10px; }
        .pdf-page-info {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
            white-space: nowrap;
        }
        .pdf-nav-btn {
            width: 30px; height: 30px;
            border: 1px solid var(--border);
            border-radius: 6px;
            background: var(--bg-card);
            color: var(--text);
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: background var(--transition), border-color var(--transition);
            font-size: 14px;
        }
        .pdf-nav-btn:hover:not(:disabled) { background: var(--bg-row-hover); border-color: var(--primary); color: var(--primary-text); }
        .pdf-nav-btn:disabled { opacity: 0.35; cursor: default; }
        .pdf-zoom-wrap { display: flex; align-items: center; gap: 6px; }
        .pdf-zoom-label { font-size: 12px; color: var(--text-muted); font-weight: 600; min-width: 42px; text-align: center; }
        .pdf-iframe-wrap {
            flex: 1;
            position: relative;
            overflow: hidden;
            border-radius: 0 0 var(--radius-md) var(--radius-md);
            background: #525659;
        }
        .pdf-canvas-wrap {
            flex: 1;
            overflow-y: auto;
            overflow-x: auto;
            background: #525659;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px 0;
            gap: 16px;
            border-radius: 0 0 var(--radius-md) var(--radius-md);
        }
        .pdf-page-canvas {
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
            display: block;
            background: #fff;
        }
        .pdf-fallback {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 16px;
            color: var(--text-muted);
            text-align: center;
            padding: 40px;
            height: 100%;
        }
        .pdf-fallback.visible { display: flex; }

        /* ========== MARKDOWN STYLES ========== */
        .markdown-body { max-width: 780px; margin: 0 auto; line-height: 1.7; }
        .markdown-body h1,.markdown-body h2,.markdown-body h3 { font-weight: 700; margin-top: 1.5em; margin-bottom: .5em; }
        .markdown-body h1 { font-size: 1.9em; border-bottom: 1px solid var(--border); padding-bottom: .3em; }
        .markdown-body h2 { font-size: 1.4em; }
        .markdown-body h3 { font-size: 1.15em; }
        .markdown-body p { margin-bottom: 1em; }
        .markdown-body code { background: var(--bg-icon-wrap); padding: .15em .4em; border-radius: 4px; font-family: monospace; font-size: .88em; }
        .markdown-body pre { background: #1e293b !important; padding: 1em; border-radius: var(--radius-md); overflow-x: auto; margin-bottom: 1em; }
        .markdown-body pre code { background: transparent; padding: 0; color: #f8fafc; }
        .markdown-body a { color: var(--primary); text-decoration: none; }
        .markdown-body a:hover { text-decoration: underline; }
        .markdown-body ul { list-style: disc; padding-left: 2em; margin-bottom: 1em; }
        .markdown-body ol { list-style: decimal; padding-left: 2em; margin-bottom: 1em; }
        .markdown-body blockquote { border-left: 4px solid var(--border); padding-left: 1em; color: var(--text-muted); margin-bottom: 1em; }
        .markdown-body img { max-width: 100%; border-radius: var(--radius-md); }
        .markdown-body table { border-collapse: collapse; width: 100%; margin-bottom: 1em; }
        .markdown-body th, .markdown-body td { border: 1px solid var(--border); padding: 8px 12px; }
        .markdown-body th { background: var(--bg-table-head); font-weight: 600; }

        /* ========== HLJS THEMES ========== */
        [data-theme="dark"] .hljs-theme-light { display: none; }
        [data-theme="light"] .hljs-theme-dark { display: none; }

        /* ========== UTILITY ========== */
        .hide { display: none !important; }

        /* ========== ICON COLOR HELPERS (applied in JS via style) ========== */
        /* Used inline via style="color: var(--ic-xxx)" */

        /* ========== RESPONSIVE ========== */
        @media (max-width: 600px) {
            .controls { flex-direction: column; }
            .search-wrap { width: 100%; }
            main { padding: 16px 12px; }
            .header { padding: 12px 16px; }
        }
    </style>

    <!-- Embedded: highlight.js themes (both, toggled via CSS) -->
    <style class="hljs-theme-dark">
.hljs{background:#282c34;color:#abb2bf}.hljs-comment,.hljs-quote{color:#5c6370;font-style:italic}.hljs-doctag,.hljs-formula,.hljs-keyword{color:#c678dd}.hljs-deletion,.hljs-name,.hljs-section,.hljs-selector-tag,.hljs-subst{color:#e06c75}.hljs-literal{color:#56b6c2}.hljs-addition,.hljs-attribute,.hljs-meta .hljs-string,.hljs-regexp,.hljs-string{color:#98c379}.hljs-attr,.hljs-number,.hljs-selector-attr,.hljs-selector-class,.hljs-selector-pseudo,.hljs-template-variable,.hljs-type,.hljs-variable{color:#d19a66}.hljs-bullet,.hljs-link,.hljs-meta,.hljs-selector-id,.hljs-symbol,.hljs-title{color:#61aeee}.hljs-built_in,.hljs-class .hljs-title,.hljs-title.class_{color:#e6c07b}.hljs-emphasis{font-style:italic}.hljs-strong{font-weight:700}.hljs-link{text-decoration:underline}
</style>
    <style class="hljs-theme-light">
.hljs{background:#fafafa;color:#383a42}.hljs-comment,.hljs-quote{color:#a0a1a7;font-style:italic}.hljs-doctag,.hljs-formula,.hljs-keyword{color:#a626a4}.hljs-deletion,.hljs-name,.hljs-section,.hljs-selector-tag,.hljs-subst{color:#e45649}.hljs-literal{color:#0184bb}.hljs-addition,.hljs-attribute,.hljs-meta .hljs-string,.hljs-regexp,.hljs-string{color:#50a14f}.hljs-attr,.hljs-number,.hljs-selector-attr,.hljs-selector-class,.hljs-selector-pseudo,.hljs-template-variable,.hljs-type,.hljs-variable{color:#986801}.hljs-bullet,.hljs-link,.hljs-meta,.hljs-selector-id,.hljs-symbol,.hljs-title{color:#4078f2}.hljs-built_in,.hljs-class .hljs-title,.hljs-title.class_{color:#c18401}.hljs-emphasis{font-style:italic}.hljs-strong{font-weight:700}.hljs-link{text-decoration:underline}
</style>
</head>
<body>

<!-- HEADER -->
<header class="header">
    <div class="header-brand">
        <div class="header-icon-wrap" id="headerServerIcon"></div>
        <span class="header-title">XFPM Serve</span>
    </div>
    <button class="btn-icon" id="themeToggle" title="Toggle theme" aria-label="Toggle theme">
        <span id="iconSun"></span>
        <span id="iconMoon" class="hide"></span>
    </button>
</header>

<!-- MAIN -->
<main>
    <div class="content-wrap">
        <!-- Controls -->
        <div class="controls">
            <!-- Breadcrumbs -->
            <div class="breadcrumb-bar">
                <button class="btn-root" onclick="navigateTo('')">
                    <span id="iconHome"></span> Root
                </button>
                <span id="breadcrumbs"></span>
            </div>
            <!-- Search -->
            <div class="search-wrap">
                <span class="search-icon" id="iconSearch"></span>
                <input type="text" class="search-input" id="searchInput" placeholder="Search recursively…" autocomplete="off">
                <span class="search-loader" id="searchLoader">
                    <span class="spin" id="iconLoaderSearch"></span>
                </span>
            </div>
        </div>

        <!-- File list -->
        <div class="file-card">
            <table>
                <thead>
                    <tr>
                        <th class="col-name">Name</th>
                        <th class="col-size">Size</th>
                    </tr>
                </thead>
                <tbody id="fileList"></tbody>
            </table>
            <div class="empty-state" id="emptyState">
                <div class="empty-icon-wrap" id="iconEmptyWrap"></div>
                <p class="empty-label">No files found.</p>
            </div>
        </div>
    </div>
</main>

<!-- VIEWER MODAL -->
<div class="overlay" id="viewerOverlay">
    <div class="modal" id="modal">
        <div class="modal-header">
            <div class="modal-title">
                <span id="modalIconSlot"></span>
                <span id="viewerTitle">File</span>
            </div>
            <div class="modal-actions">
                <a class="modal-btn" id="viewerDownloadBtn" href="#" download title="Download">
                    <span id="iconDownloadBtn"></span>
                </a>
                <button class="modal-btn close-btn" onclick="closeViewer()" title="Close">
                    <span id="iconCloseBtn"></span>
                </button>
            </div>
        </div>
        <div class="modal-body" id="modalBody">
            <!-- Loader -->
            <div class="viewer-loader" id="viewerLoader">
                <span class="spin" id="iconLoaderViewer"></span>
                <span class="loader-text">Loading…</span>
            </div>
            <!-- Code -->
            <div class="viewer-code-wrap" id="viewerCodeWrap">
                <pre><code id="viewerCode"></code></pre>
            </div>
            <!-- Markdown -->
            <div class="viewer-markdown markdown-body" id="viewerMarkdown"></div>
            <!-- Media (image/video) -->
            <div class="viewer-media" id="viewerMedia">
                <img id="viewerImage" src="" alt="" style="display:none">
                <video id="viewerVideo" controls style="display:none;max-width:100%;border-radius:12px"></video>
                <div id="viewerAudioWrap" style="display:none;flex-direction:column;align-items:center;gap:20px;padding:40px 20px;">
                    <div id="viewerAudioIcon" style="width:80px;height:80px;border-radius:50%;background:var(--primary-bg);display:flex;align-items:center;justify-content:center;color:var(--primary-text);"></div>
                    <p id="viewerAudioName" style="font-weight:600;font-size:16px;color:var(--text);text-align:center;"></p>
                    <audio id="viewerAudio" controls style="width:100%;max-width:480px;border-radius:8px;"></audio>
                </div>
            </div>
            <!-- PDF viewer -->
            <div class="viewer-pdf" id="viewerPdf">
                <div class="pdf-toolbar">
                    <div class="pdf-toolbar-left">
                        <button class="pdf-nav-btn" id="pdfPrevBtn" title="Previous page" disabled>
                            <span id="iconPdfPrev"></span>
                        </button>
                        <span class="pdf-page-info" id="pdfPageInfo">— / —</span>
                        <button class="pdf-nav-btn" id="pdfNextBtn" title="Next page" disabled>
                            <span id="iconPdfNext"></span>
                        </button>
                    </div>
                    <div class="pdf-zoom-wrap">
                        <button class="pdf-nav-btn" id="pdfZoomOut" title="Zoom out"><span id="iconZoomOut"></span></button>
                        <span class="pdf-zoom-label" id="pdfZoomLabel">100%</span>
                        <button class="pdf-nav-btn" id="pdfZoomIn" title="Zoom in"><span id="iconZoomIn"></span></button>
                    </div>
                </div>
                <div class="pdf-canvas-wrap" id="pdfCanvasWrap">
                    <!-- canvases injected here -->
                </div>
                <div class="pdf-fallback" id="pdfFallback">
                    <p style="font-weight:600;font-size:15px;">Could not render PDF</p>
                    <a class="btn-download" id="pdfFallbackLink" href="#" target="_blank">
                        <span id="iconPdfFallbackDl"></span> Open PDF
                    </a>
                </div>
            </div>

            <!-- Unsupported -->
            <div class="viewer-unsupported" id="viewerUnsupported">
                <div class="unsupported-icon" id="iconUnsupportedWrap"></div>
                <p class="unsupported-label">Cannot preview this file type.</p>
                <a class="btn-download" id="viewerDownloadLink" href="#" target="_blank">
                    <span id="iconDownloadUnsupported"></span> Download File
                </a>
            </div>
        </div>
    </div>
</div>

